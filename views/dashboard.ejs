<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>LUXE</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
        <script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <link rel="stylesheet" href="/styles/admin-nav.css">
        <link rel="stylesheet" href="/styles/dashboard.css">
        <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

    </head>
    <body>
        <%- include('partials/admin-header.ejs', { activePage: 'dashboard' }) %>

            <div class="m-4">
                <h2>Dashboard</h2>
                <p class="text-muted">Welcome back! Here's what's happening with your store.</p>

                <div class="card-container pt-2">
                    <div class="card flex-row align-items-center rounded-4">
                        <div class="card-body m-3">
                            <h5 class="card-title fs-6">Total Revenue</h5>
                            <p class="card-text fs-3 fw-bold">₹45,231.89</p>
                        </div>
                        <div class="card-img-container rounded-3 me-4" style="background-color: #dcfce7;">
                            <img src="/images/rupee.svg" class="" alt="rupee logo" style="width: 24px; height: 24px;">
                        </div>
                    </div>
                    <div class="card flex-row align-items-center rounded-4">
                        <div class="card-body m-3">
                            <h5 class="card-title fs-6">Total Orders</h5>
                            <p class="card-text fs-3 fw-bold">523</p>
                        </div>
                        <div class="card-img-container me-4 rounded-3" style="background-color: #dbeafe;">
                            <img src="/images/cart.svg" class="card-img-top rounded-2" alt="rupee logo" style="width: 24px; height: 24px;">
                        </div>
                    </div>
                    <div class="card flex-row align-items-center rounded-4">
                        <div class="card-body m-3">
                            <h5 class="card-title fs-6">Total Products</h5>
                            <p class="card-text fs-3 fw-bold">₹45,231.89</p>
                        </div>
                        <div class="card-img-container me-4 rounded-3" style="background-color: #f3e8ff;">
                            <img src="/images/package.svg" class="card-img-top rounded-2" alt="rupee logo" style="width: 24px; height: 24px;">
                        </div>
                    </div>
                    <div class="card flex-row align-items-center rounded-4">
                        <div class="card-body m-3">
                            <h5 class="card-title fs-6">Total Customers</h5>
                            <p class="card-text fs-3 fw-bold">1,203</p>
                        </div>
                        <div class="card-img-container me-4 rounded-3" style="background-color: #ffedd4;">
                            <img src="/images/user.svg" class="card-img-top rounded-2" alt="rupee logo" style="width: 24px; height: 24px;">
                        </div>
                    </div>
                </div>


                <div class="mt-4">
                    <div class="chart-container">
                        <div id="revenue" class="bg-white border p-3 rounded-4"></div>
                        <div id="orders" class="bg-white border p-3 rounded-4"></div>
                    </div>
                </div>
            </div>


        <%- include('partials/admin-footer.ejs') %>

        <script>
            const dateOptions = { weekday: "long", year: "numeric", month: "long", day: "numeric" };
            document.getElementById("currentDate").textContent = new Date().toLocaleDateString("en-US", dateOptions);
            const revenueChart = document.getElementById("revenue");
            const ordersChart = document.getElementById("orders")

            new ApexCharts(document.getElementById("revenue"), {
                chart: {
                    type: "line",
                    height: 300,
                    toolbar: { show: false },
                    animations: { enabled: true },
                },
                title: {
                    text: "Revenue Overview",
                    align: "left",
                    style: { fontSize: "20px", fontWeight: "600", color: "#1a1a1a" },
                },
                series: [{ name: "Revenue", data: [3200, 1400, 5200, 4900, 6100, 5800, 7200, 6800, 7100, 8000, 9100, 8900] }],
                xaxis: {
                    categories: ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"],
                    axisBorder: { show: false },
                    axisTicks: { show: false },
                },
                yaxis: {
                    labels: { formatter: (val) => `$${val.toLocaleString()}` },
                },
                stroke: { curve: "smooth", width: 3, colors: ["#3a81f6"] },
                grid: {
                    borderColor: "#cccccc",
                    strokeDashArray: 1,
                    xaxis: { lines: { show: false } },
                },
                dataLabels: { enabled: false },
                legend: { show: false },
                tooltip: { y: { formatter: (val) => `$${val.toLocaleString()}` } },
            }).render()


            new ApexCharts(document.getElementById("orders"), {
                chart: {
                    type: "bar",
                    height: 300,
                    toolbar: { show: false },
                    animations: { enabled: true },
                },
                title: {
                    text: "Orders Overview",
                    align: "left",
                    style: { fontSize: "20px", fontWeight: "600", color: "#1a1a1a" },
                },
                series: [{ name: "Orders", data: [45, 52, 48, 68, 61, 78, 73, 89, 75, 90, 80, 95] }],
                xaxis: {
                    categories: ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"],
                    axisBorder: { show: false },
                    axisTicks: { show: false },
                },
                plotOptions: {
                    bar: {
                        borderRadius: 4,
                        columnWidth: "80%",
                    },
                },
                colors: ["#3a81f6"],
                grid: {
                    borderColor: "#cccccc",
                    strokeDashArray: 4,
                    xaxis: { lines: { show: false } },
                },
                dataLabels: { enabled: false },
                legend: { show: false },
            }).render();

            
        </script>
    </body>
</html>
