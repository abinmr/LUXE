<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>LUXE</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
        <script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <link rel="stylesheet" href="/styles/admin-nav.css">
        <script defer src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    </head>
    <body>
        <%- include('partials/admin-header.ejs', { activePage: 'dashboard' }) %>

            <div class="charts-container d-flex gap-2 m-4 bg-white">
                <div id="revenue" class="chart"></div>
                <div id="orders" class="chart" ></div>
            </div>

            <%- include('partials/admin-footer.ejs') %>

        <script>
            const dateOptions = { weekday: "long", year: "numeric", month: "long", day: "numeric" };
            document.getElementById("currentDate").textContent = new Date().toLocaleDateString("en-US", dateOptions);
            document.addEventListener("DOMContentLoaded", function () {
                let lineChart = document.getElementById("revenue");
                const options = {
                    chart: {
                        type: 'line',
                        height: 350,
                        width: 745,
                        toolbar: {
                            show: false
                        }
                    },
                    title: {
                        text: "Revenue Overview",
                        align: "left"
                    },
                    series: [{
                        name: 'Revenue',
                        data: [3200,1400,5200,4900,6100,5800,7200,6800,7100,8000,9100,8900]
                    }],
                    xaxis: {
                        categories: ["Jan","Feb","Mar","Apr","May","Jun", "Jul","Aug","Sep","Oct","Nov","Dec"]
                    }
                };
                let chart = new ApexCharts(lineChart, options)
                chart.render()
            });

            let barChart = document.getElementById("orders");
            const barOptions = {
                chart: {
                    type: 'bar',
                    height: 350,
                    width: 745,
                    toolbar: {
                        show: false
                    }
                },
                title: {
                    text: "Orders Overview",
                    align: "left"
                },
                series: [{
                    name: 'Orders',
                    data: [45, 52, 48, 68, 61, 78, 73, 89, 75, 90, 80, 95]
                }],
                xaxis: {
                    categories: ["Jan","Feb","Mar","Apr","May","Jun", "Jul","Aug","Sep","Oct","Nov","Dec"]
                }
            }

            let orderChart = new ApexCharts(barChart, barOptions);
            orderChart.render();

        </script>
    </body>
</html>
