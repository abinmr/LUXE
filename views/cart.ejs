<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>LUXE</title>
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
            crossorigin="anonymous"
        />
        <script
            src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"
        ></script>
        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
            integrity="sha384-tViUnnbYAV00FLIhhi3v/dWt3Jxw4gZQcNoSCxCIFNJVCx7/D55/wXsrNIRANwdD"
            crossorigin="anonymous"
        />
        <link rel="stylesheet" href="/styles/navbar.css" />
        <link rel="stylesheet" href="/styles/cart.css" />
    </head>
    <body style="background-color: #fefbf8">
        <%- include('partials/navbar.ejs', { categories }) %>
        
        <section class="container mt-4">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a class="text-decoration-none" href="/">Home</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Cart</li>
                </ol>
            </nav>
            <% if (cartItems && cartItems.length > 0) { %>
            <h3 class="fw-bold fs-2">Shopping Cart</h3>
            <div class="gap-4 mt-4 item-container" style="min-height: 40vh;">
                <div class="d-flex flex-column gap-3" id="cart-list">
                    <% cartItems.forEach((cart) => { %>
                        <% if (!cart.isListed || !cart.categoryActive) { %>
                            <div class="d-flex justify-content-between align-items-center px-4 border bg-white rounded cart-item unavailable-item" data-item-id="<%= cart.itemId %>" style="height: 150px;">
                                <div class="d-flex align-items-center gap-5">
                                    <img src="<%= cart.productImage[0] %>" height="96" width="96" class="rounded" />
                                    <h5 class="text-center text-danger">Product is not longer available</h5>
                                </div>
                                <button class="btn btn-light delete-btn" data-item-id="<%= cart.itemId %>">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                        fill="none" stroke="currentColor" stroke-width="2"
                                        stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <path d="M3 6h18"></path>
                                        <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path>
                                        <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path>
                                        <line x1="10" x2="10" y1="11" y2="17"></line>
                                        <line x1="14" x2="14" y1="11" y2="17"></line>
                                    </svg>
                                </button>
                            </div>
                        <% } else if (cart.stock === 0) { %>
                            <div class="d-flex justify-content-between align-items-center px-4 border bg-white rounded cart-item unavailable-item" data-item-id="<%= cart.itemId %>" style="height: 150px;">
                                <div class="d-flex align-items-center gap-2">
                                    <input
                                    type="checkbox"
                                    class="form-check-input me-1 cart-item-checkbox"
                                    data-item-id="<%= cart.itemId %>"
                                    <%= cart.isSelected ? 'checked' : '' %>
                                    />
                                    <img src="<%= cart.productImage[0] %>" height="96" width="96" class="rounded" />
                                    <div class="ms-2">
                                        <p class="m-0 fw-bold"><%= cart.productName %></p>
                                        <div>
                                            <span class="text-muted">Size: <%= cart.size %></span>
                                            <span class="text-muted">•</span>
                                            <span class="text-muted">Color: <%= cart.color %></span>
                                        </div>
                                        <div class="d-flex mt-3">
                                            <button
                                                data-item-id="<%= cart.itemId %>"
                                                class="btn btn-light btn-sm border fw-bolder p-0 quantityMinus"
                                                style="width: 32px; height: 32px"
                                                disabled
                                                >
                                                <i class="bi bi-dash fs-5"></i>
                                            </button>
                                            <input
                                            type="number"
                                            class="qty-input text-center border-0"
                                            value="<%= cart.quantity %>"
                                            min="1"
                                            max="<%= Math.min(cart.stock, 10) %>"
                                            def
                                            readonly
                                            />
                                            <button
                                                data-item-id="<%= cart.itemId %>"
                                                data-stock="<%= cart.stock %>"
                                                class="btn btn-light btn-sm border p-0 quantityAdd"
                                                style="width: 32px; height: 32px"
                                                disabled
                                                >
                                                <i class="bi bi-plus fs-5"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <h5 class="text-center text-danger">Product out of stock</h5>
                                <div>
                                    <div class="d-flex justify-content-end">
                                        <button class="btn btn-light delete-btn stock-unavailable" data-item-id="<%= cart.itemId %>">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                                fill="none" stroke="currentColor" stroke-width="2"
                                                stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                                <path d="M3 6h18"></path>
                                                <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path>
                                                <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path>
                                                <line x1="10" x2="10" y1="11" y2="17"></line>
                                                <line x1="14" x2="14" y1="11" y2="17"></line>
                                            </svg>
                                        </button>
                                    </div>
                                    <div class="mt-5">
                                        <span class="fw-semibold">₹<%= cart.price %></span>
                                        <span class="text-decoration-line-through text-muted">₹<%= cart.compareAtPrice %></span>
                                    </div>
                                </div>
                            </div>
                        <% } else { %>
                        <div class="d-flex justify-content-between align-items-center border px-4 py-3 rounded-3 bg-white cart-item" data-item-id="<%= cart.itemId %>">
                            <div class="d-flex gap-2">
                                <input
                                    type="checkbox"
                                    class="form-check-input me-1 cart-item-checkbox"
                                    data-item-id="<%= cart.itemId %>"
                                    <%= cart.isSelected ? 'checked' : '' %>
                                />
                                <a href="/product/<%= cart.productId %>">
                                    <img src="<%= cart.productImage[0] %>" alt="<%= cart.productName %>" class="rounded-2 object-fit-cover" width="96" height="96" />
                                </a>
                                <div class="ms-2">
                                    <p class="m-0 fw-bold"><%= cart.productName %></p>
                                    <div>
                                        <span class="text-muted">Size: <%= cart.size %></span>
                                        <span class="text-muted">•</span>
                                        <span class="text-muted">Color: <%= cart.color %></span>
                                    </div>
                                    <div class="d-flex mt-3">
                                        <button
                                            data-item-id="<%= cart.itemId %>"
                                            class="btn btn-light btn-sm border fw-bolder p-0 quantityMinus"
                                            style="width: 32px; height: 32px"
                                            <%= cart.quantity <= 1 ? 'disabled' : '' %>
                                        >
                                            <i class="bi bi-dash fs-5"></i>
                                        </button>
                                        <input
                                            type="number"
                                            class="qty-input text-center border-0"
                                            value="<%= cart.quantity %>"
                                            min="1"
                                            max="<%= Math.min(cart.stock, 10) %>"
                                            readonly
                                        />
                                        <button
                                            data-item-id="<%= cart.itemId %>"
                                            data-stock="<%= cart.stock %>"
                                            class="btn btn-light btn-sm border p-0 quantityAdd"
                                            style="width: 32px; height: 32px"
                                            <%= cart.quantity >= Math.min(cart.stock, 10) ? 'disabled' : '' %>
                                        >
                                            <i class="bi bi-plus fs-5"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div>
                                <div class="d-flex justify-content-end">
                                    <button
                                        class="btn btn-light d-flex justify-content-end delete-btn"
                                        data-item-id="<%= cart.itemId %>"
                                    >
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                            fill="none" stroke="currentColor" stroke-width="2"
                                            stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                            <path d="M3 6h18"></path>
                                            <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path>
                                            <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path>
                                            <line x1="10" x2="10" y1="11" y2="17"></line>
                                            <line x1="14" x2="14" y1="11" y2="17"></line>
                                        </svg>
                                    </button>
                                </div>
                                <div class="mt-5">
                                    <span class="fw-semibold">₹<%= cart.price %></span>
                                    <span class="text-decoration-line-through text-muted">₹<%= cart.compareAtPrice %></span>
                                </div>
                            </div>
                        </div>
                        <% } %>
                    <% }) %>
                </div>

                <div class="d-flex flex-column gap-4">

                    <div class="border rounded-4 px-3 pt-5 pb-4 bg-white">
                        <div class="d-flex flex-column gap-2">
                            <div class="d-flex justify-content-between">
                                <span>Subtotal</span>
                                <div class="d-flex">
                                    <span>₹</span>
                                    <span id="subtotal"><%= pricing.subtotal %></span>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>GST</span>
                                <div class="d-flex">
                                    <span>₹</span>
                                    <span id="GST"><%= pricing.gst %></span>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Shipping</span>
                                <div class="d-flex">
                                    <span>₹</span>
                                    <span id="shipping"><%= pricing.shipping %></span>
                                </div>
                            </div>
                            <hr />
                            <div class="d-flex justify-content-between">
                                <span class="fw-bold fs-5">Total</span>
                                <div class="d-flex">
                                    <span class="fw-bold fs-5">₹</span>
                                    <span id="total" class="fw-bold fs-5"><%= pricing.total %></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <form action="/checkout" method="POST">
                        <button type="submit" id="checkout-btn" class="btn btn-danger w-100">Proceed to Checkout</button>
                    </form>
                </div>
            </div>
        </section> 
        <% } else { %>
            <section class="mt-5" style="min-height: 48vh;">
                <div class="text-center">
                    <h4 class="fw-bolder fs-3">You cart is empty</h4>
                    <p>Add items to cart that you want to buy</p>
                    <a href="/home" class="btn btn-danger">Continue Shopping</a>
                </div>
            </section>
        <% }%>

        <%- include('partials/footer.ejs') %>

        <script src="/scripts/cart.js"></script>
    </body>
</html>
