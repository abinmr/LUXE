<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>LUXE</title>
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
            crossorigin="anonymous"
        />
        <script
            src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"
        ></script> 
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" integrity="sha384-tViUnnbYAV00FLIhhi3v/dWt3Jxw4gZQcNoSCxCIFNJVCx7/D55/wXsrNIRANwdD" crossorigin="anonymous">
        <link rel="stylesheet" href="/styles/navbar.css" />
        <link rel="stylesheet" href="/styles/profile.css">
        <script defer src="/scripts/profile.js"></script>
    </head>
    <body style="background-color: #fefbf8;">
        <%- include('partials/navbar.ejs'), { categories } %>

        <div class="container my-5">
            <h2 class="fw-bold">My Account</h2>
            <div class="mt-4 row">
                <nav class="col-md-3 mb-4">
                    <div class="list-group border-0">
                        <a href="/profile?section=profile" 
                        class="d-flex align-items-center gap-2 list-group-item list-group-item-action mb-2 border-0 text-black  <%= section === 'profile' ? 'active-profile rounded' : '' %>">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user mr-2 h-4 w-4" aria-hidden="true"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                            <span> Profile Details </span>
                        </a>
                        <a href="/profile?section=password" 
                        class="d-flex align-items-center gap-2 list-group-item list-group-item-action mb-2 border-0 text-black <%= section === 'password' ? 'active-profile rounded' : '' %>">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-lock mr-2 h-4 w-4" aria-hidden="true"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                            <span>Change Password</span>
                        </a>
                        <a href="/profile?section=address" 
                        class="d-flex align-items-center gap-2 list-group-item list-group-item-action mb-2 border-0 text-black <%= section === 'address' ? 'active-profile rounded' : '' %>">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin mr-2 h-4 w-4" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path><circle cx="12" cy="10" r="3"></circle></svg>
                            <span>Addresses</span>
                        </a>
                        <a href="/profile?section=order history"
                        class="d-flex align-items-center gap-2 list-group-item list-group-item-action mb-2 border-0 text-black">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-package mr-2 h-4 w-4" aria-hidden="true"><path d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z"></path><path d="M12 22V12"></path><polyline points="3.29 7 12 12 20.71 7"></polyline><path d="m7.5 4.27 9 5.15"></path></svg>
                        <span>Order Histroy</span>
                        </a>
                        <a href="/profile/logout" class="d-flex align-items-center gap-2 list-group-item list-group-item-action mb-2 border-0 text-danger">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-log-out mr-2 h-4 w-4" aria-hidden="true"><path d="m16 17 5-5-5-5"></path><path d="M21 12H9"></path><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path></svg>
                            <span>Logout</span>
                        </a>
                    </div>
                </nav>
                <div class="col-md-9">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-4">
                            <% if (section === 'profile') { %>
                                <h4 class="fw-bold mb-4">Profile Details</h4>
                                <form action="/profile/update-profile" method="POST" enctype="multipart/form-data" id="profileForm">
                                    <div class="mb-2 d-flex flex-column justify-content-center align-items-center">
                                        <div style="position: relative; width: 80px; height: 80px; cursor: pointer;" id="avatarWrapper">
                                            <img id="avatarImg"
                                             src="<%= user.profile || '/images/profile.jpg' %>" 
                                             style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover;">
                                             <div class="d-flex justify-content-center align-items-center position-absolute bottom-0 end-0">
                                                <i class="bi bi-pencil"></i>
                                             </div>
                                        </div>
                                        <small class="text-muted mt-1">Profile photo</small>
                                        <input type="file" class="d-none" accept="image/*" name="profile" id="profileImageInput" disabled>
                                    </div>
                                    <div class="mb-1">
                                        <label for="fullName" class="form-label">Full Name</label>
                                        <input type="text" class="form-control text-muted" name="fullname" id="fullname" value="<%= locals.user.fullname %>" readonly>
                                        <div class="error-container">
                                            <p class="text-danger m-0"></p>
                                        </div>
                                    </div>
                                    <div class="mb-1">
                                        <label for="email" class="form-label">Email</label>
                                        <input type="email" class="form-control text-muted" name="email" id="email" value="<%= locals.user.email %>" readonly>
                                        <div class="error-container">
                                            <p class="text-danger m-0" id="emailError"></p>
                                        </div>
                                    </div>
                                    <div class="mb-4">
                                        <label for="phone" class="form-label">Phone</label>
                                        <input type="number" class="form-control text-muted" name="phone" id="phoneProfile" placeholder="Optional" value="<%= locals.user.phone || 'Optional' %>" readonly>
                                    </div>
                                    <button type="button" id="editProfileBtn" class="btn btn-danger" <%= locals.user.authMethod === "google" ? 'disabled' : '' %> >Edit Profile</button>
                                    <div class="d-none" id="updateProfile">
                                        <button type="submit" class="btn btn-danger" id="saveProflieBtn">Save Changes</button>
                                        <button type="button" class="btn btn-light border" id="cancelProfileBtn">Cancel</button>
                                    </div>
                                </form>
                            <% } %>
                            
                            <% if (section === 'password') { %>
                                <h4 class="fw-bold">Change Password</h4>
                                <form action="/profile/change-password" method="POST" id="passwordForm">
                                    <div class="mb-1">
                                        <label for="currentPassword" class="form-label">Current Password</label>
                                        <div class="input-group border border-1 rounded-2">
                                            <input type="password" class="form-control border-0" name="currentPassword" id="currentPassword">
                                            <button class="btn border-0" type="button" id="toggle-current-password">
                                                <i class="bi bi-eye-slash" id="current-eye-icon"></i>
                                            </button>
                                        </div>
                                        <div class="mt-1 error-container">
                                            <p class="text-danger m-0" id="currentPasswordError"></p>
                                        </div>
                                    </div>
                                    <div class="mb-1">
                                        <label for="newPassword" class="form-label">New Password</label>
                                        <div class="input-group border border-1 rounded-2">
                                            <input type="password" class="form-control border-0" name="newPassword" id="newPassword">
                                            <button class="btn border-0" type="button" id="toggle-new-password">
                                                <i class="bi bi-eye-slash" id="new-eye-icon"></i>
                                            </button>
                                        </div>
                                        <div class="error-container mt-1">
                                            <p class="text-danger m-0" id="newPasswordError"></p>
                                        </div>
                                    </div>
                                    <div class="mb-1">
                                        <label for="confirmNewPassword">Confirm New Password</label>
                                        <div class="input-group border border-1 rounded-2">
                                            <input type="password" class="form-control border-0" name="confirmPassword" id="confirmPassword">
                                            <button class="btn border-0" type="button" id="toggle-confirm-password">
                                                <i class="bi bi-eye-slash" id="confirm-eye-icon"></i>
                                            </button>
                                        </div>
                                        <div class="error-container mt-1">
                                            <p class="text-danger m-0" id="confirmPasswordError"></p>
                                        </div>
                                    </div>
                                    <div class="error-container">
                                        <p class="m-0 text-danger"><%= locals.error %> </p>
                                    </div>
                                    <button type="submit" class="btn btn-danger mt-2" <%= locals.user.authMethod === "google" ? 'disabled' : '' %> >Change Password</button>
                                </form>
                            <% } %>

                            <% if (section === 'address') { %>
                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <h4 class="fw-bold">Saved Address</h4>
                                    <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#addAddressModal">Add Address</button>
                                </div>

                                <div class="row">
                                    <% if (addresses && addresses.length > 0) { %>
                                        <% addresses.forEach((address) => { %>
                                            <div class="col-12 mb-3">
                                                <div class="card flex-row justify-content-between border p-3 rounded-2">
                                                    <div>
                                                        <p class="mb-1 text-black fw-bold fs-5"> <%= address.fullName %> </p>
                                                        <p class="mb-1 text-muted"> <%= address.phone %> </p>
                                                        <p class="mb-1 fw-semibold"> <%= address.street %> </p>
                                                        <p class="mb-1 fw-semibold"> <%= address.state %> - <%= address.pincode %> </p>
                                                        <h6>
                                                            <% if(address.isDefault){ %>
                                                                <span class="btn btn-danger btn-sm rounded-2 mt-2 fw-bold">Default</span>
                                                            <% } %>
                                                        </h6>
                                                    </div>
                                                    <div class="d-flex flex-column align-items-center gap-4">
                                                        <div data-bs-toggle="modal" data-bs-target="#editModal-<%= address._id %>">
                                                            <button class="btn btn-light border">
                                                                <i class="bi bi-pencil"></i>
                                                            </button>
                                                        </div>
                                                        <div data-bs-toggle="modal" data-bs-target="#deleteModal-<%= address._id %>">
                                                            <button class="btn btn-light text-danger border">
                                                                <i class="bi bi-trash3"></i>
                                                            </button>
                                                        </div>
                                                    </div>

                                                    <div class="modal fade" id="deleteModal-<%= address._id %>" tabindex="-1" aria-hidden="true">
                                                        <div class="modal-dialog modal-dialog-centered">
                                                            <div class="modal-content">
                                                                <div class="modal-header border-0">
                                                                    <h5 class="modal-title">Delete Address?</h5>
                                                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                                </div>
                                                                <div class="modal-body pb-2">
                                                                    <p class="mb-0 text-muted">Are you sure you want to delete this address.</p>
                                                                </div>
                                                                <div class="modal-footer border-0">
                                                                    <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Cancel</button>
                                                                    <a href="/profile/address/delete/<%= address._id %>">
                                                                        <button type="button" class="btn btn-danger" >Delete</button>
                                                                    </a>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                <div class="modal fade" id="editModal-<%= address._id %>" tabindex="-1" aria-hidden="true"> 
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content p-2">
                                            <div class="modal-header border-0 pb-0">
                                                <h5 class="modal-title fw-bold">Edit Address</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>

                                            <form action="/profile/address/edit/<%= address._id %>" class="form" method="POST" id="edit-form">
                                                <div class="modal-body">
                                                    <div class="mb-3">
                                                        <label for="fullName" class="form-label">Full Name</label>
                                                        <input type="text" class="form-control fullNameAddress" name="fullName" placeholder="full name" required value="<%= address.fullName || '' %>" >
                                                        <div class="error-container">
                                                            <p class="text-danger mb-0 small fullnameError"></p>
                                                        </div>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="phone" class="form-label">Mobile Number</label>
                                                        <input type="number" class="form-control mobile-number" name="phone" placeholder="phone" maxlength="10" required value="<%= address.phone || '' %>" >
                                                        <div class="error-container">
                                                            <p class="text-danger mb-0 small mobile-error"></p>
                                                        </div>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="pincode">Pincode</label>
                                                        <input type="text" class="form-control pincode" name="pincode" placeholder="pincode" required value="<%= address.pincode || '' %>" >
                                                        <div class="error-container">
                                                            <p class="text-danger mb-0 small pincode-error"></p>
                                                        </div>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="house" class="form-label">House No / Building / Apartment</label>
                                                        <input type="text" class="form-control house-number" name="house" placeholder="Building name, House No" required value="<%= address.houseNumber || '' %>" >
                                                        <div>
                                                            <p class="text-danger mb-0 small house-error"></p>
                                                        </div>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="street" class="form-label">Street</label>
                                                        <input type="text" class="form-control street" name="street" placeholder="Street" value="<%= address.street || '' %>">
                                                        <div class="error-container">
                                                            <p class="text-danger mb-0 small street-error"></p>
                                                        </div>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="city" class="form-label">Town / City</label>
                                                        <input type="text" class="form-control" name="city" placeholder="city" value="<%= address.city || '' %>">
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="state" class="form-label">State</label>
                                                        <input type="text" class="form-control state" name="state" id="edit-state" placeholder="state" value="<%= address.state || '' %>" >
                                                        <div class="error-container">
                                                            <p class="text-danger mb-0 small state-error"></p>
                                                        </div>
                                                    </div>
                                                    <div class="form-check mb-3">
                                                        <input type="checkbox" <%= address.isDefault ? 'checked' : ''%> class="form-check-input" name="isDefault">
                                                        <label for="isDefault">Make this my default address</label>
                                                    </div>
                                                </div>

                                                <div class="modal-footer border-0 pt-0">
                                                    <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-danger px-5">Save Address</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                                                </div>
                                            </div>
                                        <% }); %>
                                    <% } else { %>
                                        <div class="mt-2 text-center">
                                            <p>No saved address yet</p>
                                            <p>Add an address</p>
                                        </div>
                                    <% } %>
                                </div>


                                <div class="modal fade" id="addAddressModal" tabindex="1" aria-hidden="true"> 
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content p-2">
                                            <div class="modal-header border-0 pb-0">
                                                <h5 class="modal-title fw-bold">Add New Address</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>

                                            <form action="/profile/add-address" class="form" method="POST" id="addAddress">
                                                <div class="modal-body">
                                                    <div class="mb-3">
                                                        <label for="fullName" class="form-label">Full Name</label>
                                                        <input type="text" class="form-control fullNameAddress" name="fullName" id="fullNameAddress" placeholder="full name">
                                                        <div class="error-container">
                                                            <p class="text-danger mb-0 small fullnameError"></p>
                                                        </div>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="phone" class="form-label">Mobile Number</label>
                                                        <input type="number" class="form-control mobile-number" name="phone" id="addPhone" placeholder="phone" minlength="10">
                                                        <div class="error-container">
                                                            <p class="text-danger small mb-0 mobile-error" id="phoneError"></p>
                                                        </div>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="pincode">Pincode</label>
                                                        <input type="text" class="form-control pincode" name="pincode" id="addPincode" placeholder="pincode" minlength="6">
                                                        <div class="error-container">
                                                            <p class="text-danger small mb-0 mt-1 pincode-error" id="pincodeError"></p>
                                                        </div>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="house" class="form-label">House No / Building / Apartment</label>
                                                        <input type="text" class="form-control house-number" name="house" id="house" placeholder="Building name, House No">
                                                        <div class="error-container">
                                                            <p id="house-error" class="text-danger mb-0 mt-1 house-error"></p>
                                                        </div>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="street" class="form-label">Street</label>
                                                        <input type="text" class="form-control street" name="street" id="street" placeholder="Street">
                                                        <div class="error-container">
                                                            <p id="street-error" class="text-danger mb-0 small street-error"></p>
                                                        </div>
                                                   </div>
                                                    <div class="mb-3">
                                                        <label for="city" class="form-label">Town / City</label>
                                                        <input type="text" class="form-control" name="city" id="city" placeholder="city">
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="state" class="form-label">State</label>
                                                        <input type="text" class="form-control state" name="state" id="state" placeholder="state">
                                                        <div class="error-container">
                                                            <p class="text-danger mb-0 small state-error"></p>
                                                        </div>
                                                    </div>
                                                    <div class="form-check mb-3">
                                                        <input type="checkbox" class="form-check-input" name="isDefault">
                                                        <label for="isDefault">Make this my default address</label>
                                                    </div>
                                                </div>

                                                <div class="modal-footer border-0 pt-0">
                                                    <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Cancel</button>
                                                    <button type="submit" id="address-submit" class="btn btn-danger px-5">Save Address</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            <% } %>

                            <% if (section === "order history") { %>
                                <h4>Order History</h4>
                                <div class="p-4 border border-1 rounded-4 mt-4">
                                    <a href="/profile/orders/detail" class="d-flex justify-content-between align-items-center text-decoration-none">
                                        <div class="d-flex align-items-center gap-4">
                                            <img src="/images/product-03.png" class="rounded-2" height="80" width="80">
                                            <div>
                                                <p class="mb-2">Order #1776427909055</p>
                                                <span class="text-muted">17 Apr 2026</span>
                                            </div>
                                        </div>
                                        <div>
                                            <button class="btn btn-danger">placed</button>
                                        </div>
                                    </a>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="toast-container position-fixed top-0 end-0 px-3 pt-5 mt-5">
            <div id="actionToast" class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body d-flex gap-2 align-items-center fw-bold">
                        <svg id="toast-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" height="20" width="20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"></path></svg>

                        <div id="actionToastBody">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <% if (locals.toast) { %>
            <script>
                window.initialToast = <%- JSON.stringify(toast) %>;
            </script>
        <% } %>
    </body>
</html>
