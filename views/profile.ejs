<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>LUXE</title>
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
            crossorigin="anonymous"
        />
        <script
            src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"
        ></script> 
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" integrity="sha384-tViUnnbYAV00FLIhhi3v/dWt3Jxw4gZQcNoSCxCIFNJVCx7/D55/wXsrNIRANwdD" crossorigin="anonymous">
        <link rel="stylesheet" href="/styles/navbar.css" />
        <link rel="stylesheet" href="/styles/profile.css">
        <script defer src="/scripts/profile.js"></script>
    </head>
    <body style="background-color: #fefbf8;">
        <%- include('partials/navbar.ejs'), { categories } %>
        <hr class="my-0" />

        <div class="container my-5">
            <h2 class="fw-bold">My Account</h2>
            <div class="mt-4 row">
                <nav class="col-md-3 mb-4">
                    <div class="list-group border-0">
                        <a href="/profile?section=profile" 
                        class="list-group-item list-group-item-action mb-2 border-0 text-black  <%= section === 'profile' ? 'active-profile rounded' : '' %>">
                        <span><i class="bi bi-person"></i></span>
                           Profile Details
                        </a>
                        <a href="/profile?section=password" 
                        class="list-group-item list-group-item-action mb-2 border-0 text-black <%= section === 'password' ? 'active-profile rounded' : '' %>">
                        <span><i class="bi bi-lock"></i></span>
                            Change Password
                        </a>
                        <a href="/profile?section=address" 
                        class="list-group-item list-group-item-action mb-2 border-0 text-black <%= section === 'address' ? 'active-profile rounded' : '' %>">
                        <span><i class="bi bi-geo-alt"></i></span>
                             Addresses
                        </a>
                        <a href="/profile/logout" class="list-group-item list-group-item-action mb-2 border-0 text-danger">
                            <span><i class="bi bi-box-arrow-in-right"></i></span>
                            Logout
                        </a>
                    </div>
                </nav>
                <div class="col-md-9">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-4">
                            <% if (section === 'profile') { %>
                                <h4 class="fw-bold mb-4">Profile Details</h4>
                                <form action="/profile/update-profile" method="POST" enctype="multipart/form-data" id="profileForm">
                                    <div class="mb-2 d-flex flex-column justify-content-center align-items-center">
                                        <div style="position: relative; width: 80px; height: 80px; cursor: pointer;" id="avatarWrapper">
                                            <img id="avatarImg"
                                             src="<%= user.profile || '/images/profile.jpg' %>" 
                                             style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover;">
                                             <div class="d-flex justify-content-center align-items-center position-absolute bottom-0 end-0">
                                                <i class="bi bi-pencil"></i>
                                             </div>
                                        </div>
                                        <small class="text-muted mt-1">Profile photo</small>
                                        <input type="file" class="d-none" accept="image/*" name="profile" id="profileImageInput" disabled>
                                    </div>
                                    <div class="mb-1">
                                        <label for="fullName" class="form-label">Full Name</label>
                                        <input type="text" class="form-control text-muted" name="fullname" id="fullname" value="<%= locals.user.fullname %>" readonly>
                                        <div class="error-container">
                                            <p class="text-danger m-0"></p>
                                        </div>
                                    </div>
                                    <div class="mb-1">
                                        <label for="email" class="form-label">Email</label>
                                        <input type="email" class="form-control text-muted" name="email" id="email" value="<%= locals.user.email %>" readonly>
                                        <div class="error-container">
                                            <p class="text-danger m-0" id="emailError"></p>
                                        </div>
                                    </div>
                                    <div class="mb-4">
                                        <label for="phone" class="form-label">Phone</label>
                                        <input type="number" class="form-control text-muted" name="phone" id="phoneProfile" placeholder="<%= locals.user.phone || 'Optional' %>" readonly>
                                    </div>
                                    <button type="button" id="editProfileBtn" class="btn btn-danger" <%= locals.user.authMethod === "google" ? 'disabled' : '' %> >Edit Profile</button>
                                    <div class="d-none" id="updateProfile">
                                        <button type="submit" class="btn btn-danger" id="saveProflieBtn">Save Changes</button>
                                        <button type="button" class="btn btn-light border" id="cancelProfileBtn">Cancel</button>
                                    </div>
                                </form>
                            <% } %>
                            
                            <% if (section === 'password') { %>
                                <h4 class="fw-bold">Change Password</h4>
                                <form action="/profile/change-password" method="POST" id="passwordForm">
                                    <div class="mb-1">
                                        <label for="currentPassword" class="form-label">Current Password</label>
                                        <div class="input-group border border-1 rounded-2">
                                            <input type="password" class="form-control border-0" name="currentPassword" id="currentPassword">
                                            <button class="btn border-0" type="button" id="toggle-current-password">
                                                <i class="bi bi-eye-slash" id="current-eye-icon"></i>
                                            </button>
                                        </div>
                                        <div class="mt-1 error-container">
                                            <p class="text-danger m-0" id="currentPasswordError"></p>
                                        </div>
                                    </div>
                                    <div class="mb-1">
                                        <label for="newPassword" class="form-label">New Password</label>
                                        <div class="input-group border border-1 rounded-2">
                                            <input type="password" class="form-control border-0" name="newPassword" id="newPassword">
                                            <button class="btn border-0" type="button" id="toggle-new-password">
                                                <i class="bi bi-eye-slash" id="new-eye-icon"></i>
                                            </button>
                                        </div>
                                        <div class="error-container mt-1">
                                            <p class="text-danger m-0" id="newPasswordError"></p>
                                        </div>
                                    </div>
                                    <div class="mb-1">
                                        <label for="confirmNewPassword">Confirm New Password</label>
                                        <div class="input-group border border-1 rounded-2">
                                            <input type="password" class="form-control border-0" name="confirmPassword" id="confirmPassword">
                                            <button class="btn border-0" type="button" id="toggle-confirm-password">
                                                <i class="bi bi-eye-slash" id="confirm-eye-icon"></i>
                                            </button>
                                        </div>
                                        <div class="error-container mt-1">
                                            <p class="text-danger m-0" id="confirmPasswordError"></p>
                                        </div>
                                    </div>
                                    <div class="error-container">
                                        <p class="m-0 text-danger"><%= locals.error %> </p>
                                    </div>
                                    <button type="submit" class="btn btn-danger mt-2" <%= locals.user.authMethod === "google" ? 'disabled' : '' %> >Change Password</button>
                                </form>
                            <% } %>

                            <% if (section === 'address') { %>
                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <h4 class="fw-bold">Saved Address</h4>
                                    <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#addAddressModal">Add Address</button>
                                </div>

                                <div class="row">
                                    <% if (addresses && addresses.length > 0) { %>
                                        <% addresses.forEach(address => { %>
                                            <div class="col-12 mb-3">
                                                <div class="card flex-row justify-content-between border p-3 rounded-2">
                                                    <div>
                                                        <p class="mb-1 text-black fw-bold fs-5"> <%= address.fullName %> </p>
                                                        <p class="mb-1 text-muted"> <%= address.phone %> </p>
                                                        <p class="mb-1 fw-semibold"> <%= address.street %> </p>
                                                        <p class="mb-1 fw-semibold"> <%= address.state %> - <%= address.pincode %> </p>
                                                        <h6><% if(address.isDefault){ %><span class="btn btn-danger btn-sm rounded-2 mt-2 fw-bold">Default</span><% } %></h6>
                                                    </div>
                                                    <div class="d-flex flex-column align-items-center gap-4">
                                                        <div data-bs-toggle="modal" data-bs-target="#editModal-<%= address._id %>">
                                                            <button class="btn btn-light border">
                                                                <i class="bi bi-pencil"></i>
                                                            </button>
                                                        </div>
                                                        <div data-bs-toggle="modal" data-bs-target="#deleteModal-<%= address._id %>">
                                                            <button class="btn btn-light text-danger border">
                                                                <i class="bi bi-trash3"></i>
                                                            </button>
                                                        </div>
                                                    </div>

                                                    <div class="modal fade" id="deleteModal-<%= address._id %>" tabindex="-1" aria-hidden="true">
                                                        <div class="modal-dialog modal-dialog-centered">
                                                            <div class="modal-content">
                                                                <div class="modal-header border-0">
                                                                    <h5 class="modal-title">Delete Address?</h5>
                                                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                                </div>
                                                                <div class="modal-body pb-2">
                                                                    <p class="mb-0 text-muted">Are you sure you want to delete this address.</p>
                                                                </div>
                                                                <div class="modal-footer border-0">
                                                                    <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Cancel</button>
                                                                    <a href="/profile/address/delete/<%= address._id %>">
                                                                        <button type="button" class="btn btn-danger" >Delete</button>
                                                                    </a>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                    <div class="modal fade" id="editModal-<%= address._id %>" tabindex="-1" aria-hidden="true"> 
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content p-2">
                                            <div class="modal-header border-0 pb-0">
                                                <h5 class="modal-title fw-bold">Add New Address</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>

                                            <form action="/profile/address/edit/<%= address._id %>" method="POST">
                                                <div class="modal-body">
                                                    <div class="mb-3">
                                                        <label for="fullName" class="form-label">Full Name</label>
                                                        <input type="text" class="form-control" name="fullName" id="fullName" placeholder="full name" required value="<%= address.fullName || '' %>" >
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="phone" class="form-label">Mobile Number</label>
                                                        <input type="number" class="form-control" name="phone" id="phoneEdit" placeholder="phone" maxlength="10" required value="<%= address.phone || '' %>" >
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="pincode">Pincode</label>
                                                        <input type="number" class="form-control" name="pincode" id="pincode" placeholder="pincode" required value="<%= address.pincode || '' %>" >
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="house" class="form-label">House No / Building / Apartment</label>
                                                        <input type="text" class="form-control" name="house" id="house" placeholder="Building name, House No" required value="<%= address.houseNumber || '' %>" >
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="street" class="form-label">Street</label>
                                                        <input type="text" class="form-control" name="street" id="street" placeholder="Street" value="<%= address.street || '' %>">
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="city" class="form-label">Town / City</label>
                                                        <input type="text" class="form-control" name="city" id="city" placeholder="city" required value="<%= address.city || '' %>">
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="state" class="form-label">State</label>
                                                        <input type="text" class="form-control" name="state" id="state" placeholder="state" required value="<%= address.state || '' %>" >
                                                    </div>
                                                    <div class="form-check mb-3">
                                                        <input type="checkbox" <%= address.isDefault ? 'checked' : ''%> class="form-check-input" name="isDefault">
                                                        <label for="isDefault">Make this my default address</label>
                                                    </div>
                                                </div>

                                                <div class="modal-footer border-0 pt-0">
                                                    <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-danger px-5">Save Address</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>


                                                </div>
                                            </div>
                                        <% }); %>
                                    <% } else { %>
                                        <div class="mt-2 text-center">
                                            <p>No saved address yet</p>
                                            <p>Add an address</p>
                                        </div>
                                    <% } %>
                                </div>


                                <div class="modal fade" id="addAddressModal" tabindex="1" aria-hidden="true"> 
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content p-2">
                                            <div class="modal-header border-0 pb-0">
                                                <h5 class="modal-title fw-bold">Add New Address</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>

                                            <form action="/profile/add-address" method="POST" id="addAddress">
                                                <div class="modal-body">
                                                    <div class="mb-3">
                                                        <label for="fullName" class="form-label">Full Name</label>
                                                        <input type="text" class="form-control" name="fullName" id="fullName" placeholder="full name" required>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="phone" class="form-label">Mobile Number</label>
                                                        <input type="number" class="form-control" name="phone" id="addPhone" placeholder="phone" minlength="10" required>
                                                        <p class="text-danger small mb-0" id="phoneError"></p>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="pincode">Pincode</label>
                                                        <input type="number" class="form-control" name="pincode" id="addPincode" placeholder="pincode" minlength="6" required>
                                                        <p class="text-danger small mb-0 mt-1" id="pincodeError"></p>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="house" class="form-label">House No / Building / Apartment</label>
                                                        <input type="text" class="form-control" name="house" id="house" placeholder="Building name, House No" required>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="street" class="form-label">Street</label>
                                                        <input type="text" class="form-control" name="street" id="street" placeholder="Street">
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="city" class="form-label">Town / City</label>
                                                        <input type="text" class="form-control" name="city" id="city" placeholder="city" required>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="state" class="form-label">State</label>
                                                        <input type="text" class="form-control" name="state" id="state" placeholder="state" required>
                                                    </div>
                                                    <div class="form-check mb-3">
                                                        <input type="checkbox" class="form-check-input" name="isDefault">
                                                        <label for="isDefault">Make this my default address</label>
                                                    </div>
                                                </div>

                                                <div class="modal-footer border-0 pt-0">
                                                    <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-danger px-5">Save Address</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>

            <% if (locals.toast) { %>
                <div class="toast-container position-fixed bottom-0 end-0 p-3 m-2">
                    <div id="actionToast" class="toast align-items-center" role="alert" aria-live="assertive" aria-atomic="true">
                        <div class="d-flex">
                            <div class="toast-body fw-semibold <%= locals.toast.type === 'success' ? 'text-success' : 'text-danger' %>">
                                <%= locals.toast.message %>
                            </div>
                        </div>
                    </div>
                </div>

                <script>
                    document.addEventListener("DOMContentLoaded", () => {
                        const toastEl = document.getElementById("actionToast");
                        const toast = new bootstrap.Toast(toastEl, { delay: 3000 });
                        toast.show();
                    });
                </script>

            <% } %>

            <script>
                const avatarWrapper = document.getElementById("avatarWrapper");
                const profileImageInput = document.getElementById("profileImageInput")
                const avatarImg = document.getElementById("avatarImg");

                avatarImg.addEventListener("click", () => profileImageInput.click())

                profileImageInput.addEventListener("change", () => {
                    const file = profileImageInput.files[0];
                    if (file) avatarImg.src = URL.createObjectURL(file);
                })
            </script>
    </body>
</html>
