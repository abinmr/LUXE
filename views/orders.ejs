<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>LUXE</title>
    <link rel="stylesheet" href="/styles/admin-nav.css">
</head>
<body>
    
    <%- include('partials/admin-header.ejs', { activePage: 'orders' }) %>
    <div class="m-4">
        <h2>Orders</h2>
        <p class="text-muted">Manage and track customer orders</p>

        <div class="border border-1 rounded-4 p-4 mt-4 bg-white">
            <form action="/admin/orders" method="GET" id="searchForm" class="d-flex align-items-center gap-2">
                <div class="input-group flex-grow-1 focus-ring-wrapper me-2 rounded-3">
                    <span class="input-group-text border-0 text-muted" style="background-color: #f3f3f5;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
                    </span>
                    <input type="search" value="<%= locals.search || '' %>" id="searchCustomer" name="search" class="form-control border-0 shadow-none" placeholder="search orders..." style="background-color: #f3f3f5;" autofocus>
                </div>
                <a href="/admin/orders" class="btn btn-danger btn-sm rounded-2">Cancel</a>
                <button class="btn btn-primary btn-sm fw-semibold rounded-2">Submit</button>
                <select name="customerStatus" id="customerStatus" class="form-select form-select-sm w-auto shadow-none text-dark rounded-2" style="min-width: 200px; font-size: 15px; border-color: #f2f2f2;">
                    <option value="all-status">All Status</option>
                    <option value="processing">Processing</option>
                    <option value="shipped">Shipped</option>
                    <option value="delivered">Delivered</option>
                    <option value="pending">Pending</option>
                    <option value="return-request">Return Request</option>
                    <option value="cancelled">Cancelled</option>
                </select>
            </form>
        </div>

        <div class="bg-white mt-4 px-3 py-4 border rounded-4">
            <div>
                <h5>All Orders</h5>
            </div>
            <table class="table mt-4">
                <thead>
                    <th scope="col">Customer</th>
                    <th scope="col">Date</th>
                    <th scope="col">Items</th>
                    <th scope="col">Total</th>
                    <th scope="col">Status</th>
                    <th scope="col">Action</th>
                </thead>
                <tbody>
                    <th scope="row">John Does</th>
                    <td>Feb 10, 2026</td>
                    <td>3</td>
                    <td>₹249.99</td>
                    <td>
                        <span class="btn btn-sm bg-secondary-subtle rounded-2 py-1 ">processing</span>
                    </td>
                    <td>
                        <a href="/admin/orders/details" class="btn btn-light btn-sm rounded-2">
                            <img src="/images/view-details.svg" alt="">
                            view
                        </a>
                    </td>
                </tbody>
            </table>
        </div>

    </div>
    <%- include('partials/admin-footer.ejs') %>
</body>
</html>

