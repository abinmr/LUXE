<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>LUXE</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
        <script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <!-- <link rel="stylesheet" href="/styles/admin-login.css" />
        <link rel="stylesheet" href="/styles/main.css" /> -->
    </head>
    <body>
        <div class="container d-flex justify-content-center align-items-center min-vh-100">
            <div class="border rounded-4 shadow-sm col-5">
                <div class="text-center mt-5 mb-3">
                    <div class="bg-primary rounded-4 d-flex justify-content-center align-items-center mx-auto" style="width: 64px; height: 64px">
                        <img src="/images/admin-logo.svg" alt="" />
                    </div>
                    <h2 class="mt-4 fw-semibold">Admin</h2>
                    <p class="text-muted">E-Commerce Platform</p>
                </div>
                <div class="error-container text-center text-danger pb-1">
                    <% if (locals.error) { %>
                        <p class="fw-semibold"> <%= error %> </p>
                    <% } %>
                </div>
                <form action="/api/admin/login" method="POST" class="d-flex flex-column justify-content-center align-items-center">
                    <div class="mb-3 w-75">
                        <label for="email" class="form-label">Email Address</label>
                        <input type="email" class="form-control" name="email" id="email" placeholder="email" />
                    </div>
                    <div class="mb-2 w-75">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" class="form-control" name="password" id="password" placeholder="password" />
                    </div>
                    <button type="submit" class="btn btn-primary mt-4 mb-5">Sign In to Dashboard</button>
                </form>
            </div>
        </div>
    </body>
</html>
