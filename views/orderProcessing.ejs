<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" integrity="sha384-tViUnnbYAV00FLIhhi3v/dWt3Jxw4gZQcNoSCxCIFNJVCx7/D55/wXsrNIRANwdD" crossorigin="anonymous" />
    <title>LUXE</title>
    <link rel="stylesheet" href="/styles/admin-nav.css" />
    <link rel="stylesheet" href="/styles/adminCategory.css">
</head>
<body style="background-color: #f9fafb;">
    <%- include('partials/admin-header.ejs', { activePage: 'orders' }) %>

    <div class="m-4">
        <div class="d-flex mb-4">
            <a href="/admin/orders" class="btn btn-light border-0 me-3" style="align-self: center;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
            </a>
            <div>
                <h2>Order Details</h2>
                <p class="text-muted">details about the order</p>
            </div>

        </div>
        <div class="border border-1 rounded-4 bg-white">
            <div class="mt-4 px-4">

                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted fw-semibold">Order date</h6>
                        <h5 class="fw-semibold">Tuesday, February 10, 2026</h5>
                    </div>
                    <button class="btn btn-light border border-1 rounded-3">processing</button>
                </div>
                <hr class="text-muted">

                <div class="d-flex justify-content-start align-items-center gap-4 my-4">
                    <div class="w-100">
                        <div class="d-flex align-items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user w-5 h-5"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                            <span class="fw-semibold h5 mb-0">Customer Information</span>
                        </div>
                        <div class="p-4 mt-3 rounded-4" style="background-color: #f9fafb;">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span>Name</span>
                                <span>John Doe</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span>Email</span>
                                <span>john@gmail.com</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span>Phone</span>
                                <span>+91 98765 43210</span>
                            </div>
                        </div>
                    </div>
                    <div class="w-100">
                        <div class="d-flex align-items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin w-5 h-5"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path><circle cx="12" cy="10" r="3"></circle></svg>
                            <span class="fw-semibold h5 mb-0">Shipping Address</span>
                        </div>
                        <div class="p-4 mt-3 rounded-3" style="background-color: #f9fafb;">
                            <div class="d-flex flex-column">
                                <span class="fw-bold mb-3">123 Main Street</span>
                                <span class="text-muted mb-3">Mumbai, Maharashtra 400001</span>
                                <span class="text-muted">India</span>
                            </div>
                        </div>
                    </div>
                </div>
                <hr class="text-muted">

                <div class="my-4">
                    <div class="d-flex align-items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-package w-5 h-5"><path d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z"></path><path d="M12 22V12"></path><polyline points="3.29 7 12 12 20.71 7"></polyline><path d="m7.5 4.27 9 5.15"></path></svg>
                        <span class="fw-semibold h5 mb-0">Order Items</span>
                    </div>

                    <div class="border border-1 rounded-4 p-4 mt-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-4">
                                <div>
                                    <img src="/images/product-03.png" class="rounded-2" height="80" width="80">
                                </div>
                                <div>
                                    <p class="mb-2 fw-semibold">Linen Shirt</p>
                                    <span class="text-muted">Quantity 1</span>
                                </div>
                            </div>
                            <div>
                                <span class="fw-bold">₹2999.00</span>
                            </div>
                        </div>
                    </div>
                                        <div class="border border-1 rounded-4 p-4 mt-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-4">
                                <div>
                                    <img src="/images/product-03.png" class="rounded-2" height="80" width="80">
                                </div>
                                <div>
                                    <p class="mb-2 fw-semibold">Linen Shirt</p>
                                    <span class="text-muted">Quantity 1</span>
                                </div>
                            </div>
                            <div>
                                <span class="fw-bold">₹2999.00</span>
                            </div>
                        </div>
                    </div>

                </div>

                <hr class="text-muted">
                <div class="my-4 d-flex justify-content-between gap-4">
                    <div class="w-100">
                        <div>
                            <span>Update Status</span>
                        </div>
                        <div class="mt-2">
                            <form action="">
                                <span class="small">Order status</span>
                                <select class="form-select mt-2" name="status" id="status">
                                    <option value="processing">Processing</option>
                                    <option value="shipped">Shipped</option>
                                    <option value="delivered">Delivered</option>
                                </select>
                                <button type="submit" class="btn btn-primary mt-4 w-100">Save Changes</button>
                            </form>
                        </div>
                    </div>
                    <div class="w-100">
                        <div>
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-credit-card w-5 h-5"><rect width="20" height="14" x="2" y="5" rx="2"></rect><line x1="2" x2="22" y1="10" y2="10"></line></svg>
                            <span>Payment Summary</span>
                        </div>
                        <div class="p-4 rounded-4 mt-2" style="background-color: #f9fafb;">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Subtotal</span>
                                <span class="fw-semibold">₹233.97</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Shipping</span>
                                <span class="fw-semibold">₹40.00</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>GST</span>
                                <span class="fw-semibold">₹13.00</span>
                            </div>
                            <hr class="text-muted">
                            <div class="d-flex justify-content-between">
                                <span class="fw-bold">Total</span>
                                <span class="text-primary fw-bold">₹259.97</span>
                            </div>
                            <hr class="text-muted">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Payment Method</span>
                                <span>Debit Cart</span>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>
