<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" integrity="sha384-tViUnnbYAV00FLIhhi3v/dWt3Jxw4gZQcNoSCxCIFNJVCx7/D55/wXsrNIRANwdD" crossorigin="anonymous" />
    <title>LUXE</title>
    <link rel="stylesheet" href="/styles/admin-nav.css" />
    <link rel="stylesheet" href="/styles/adminCategory.css">
</head>
<body style="background-color: #f9fafb;">
    <%- include('partials/admin-header.ejs', { activePage: 'orders' }) %>

    <div class="m-4">
        <div class="d-flex mb-4">
            <a href="/admin/orders" class="btn btn-light border-0 me-3" style="align-self: center;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
            </a>
            <div>
                <h2>Order Details</h2>
                <p class="text-muted">details about the order</p>
            </div>

        <!-- <% const options = { weekday: 'long', year: 'numeric', month: 'short', day: 'numeric' }; %> -->
        </div>
        <div class="border border-1 rounded-4 bg-white">
            <div class="mt-4 px-4">

                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted fw-semibold">Order date</h6>
                        <h5 class="fw-semibold"><%= order.createdAt.toLocaleDateString('en-US', options) %></h5>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <% const hasReturnRequested = order.items.some(item => item.orderStatus === "return-requested"); %>
                        <% if (hasReturnRequested) { %>
                            <button class="btn btn-light border rounded-3 d-flex align-items-center gap-2" id="process-return-btn" data-bs-toggle="modal" data-bs-target="#returnModal">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-rotate-ccw w-4 h-4 mr-2"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path></svg>
                                Process Return
                            </button>
                        <% } %>
                        <%
                            let overallStatus = order.items[0].orderStatus;
                            let btnClass = 'btn-light border';

                            const btnActiveItem = order.items.find(item => ['pending', 'processing', 'shipped'].includes(item.orderStatus));
                            const returnReqItem = order.items.find(item => item.orderStatus === 'return-requested');

                            if (btnActiveItem) {
                                overallStatus = btnActiveItem.orderStatus;
                            } else if (returnReqItem) {
                                overallStatus = 'return-requested';
                                btnClass = 'btn-danger';
                            } else {
                                if (['cancelled', 'returned'].includes(overallStatus)) {
                                    btnClass = 'btn-danger';
                                } else if (overallStatus === 'delivered') {
                                    btnClass = 'btn-success';
                                }
                            }
                        %>
                        <button id="order-status-btn" class="btn <%= btnClass %> rounded-3 text-capitalize"><%= overallStatus %></button>
                    </div>
                </div>
                <hr class="text-muted">

                <div class="d-flex justify-content-start align-items-center gap-4 my-4">
                    <div class="w-100">
                        <div class="d-flex align-items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user w-5 h-5"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                            <span class="fw-semibold h5 mb-0">Customer Information</span>
                        </div>
                        <div class="p-4 mt-3 rounded-4" style="background-color: #f9fafb;">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span>Name</span>
                                <span> <%= order.userId.fullname %></span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span>Email</span>
                                <span> <%= order.userId.email %> </span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span>Phone</span>
                                <span> <%= order.userId.phone || "unavailable" %> </span>
                            </div>
                        </div>
                    </div>
                    <div class="w-100">
                        <div class="d-flex align-items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin w-5 h-5"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path><circle cx="12" cy="10" r="3"></circle></svg>
                            <span class="fw-semibold h5 mb-0">Shipping Address</span>
                        </div>
                        <div class="p-4 mt-3 rounded-3" style="background-color: #f9fafb;">
                            <div class="d-flex flex-column">
                                <span class="fw-bold mb-3"> <%= order.shippingAddress.street %> </span>
                                <span class="text-muted mb-3"> <%= order.shippingAddress.city %> , <%= order.shippingAddress.state %> - <%= order.shippingAddress.pincode %> </span>
                                <span class="text-muted">India</span>
                            </div>
                        </div>
                    </div>
                </div>
                <hr class="text-muted">

                <div class="my-4">
                    <div class="d-flex align-items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-package w-5 h-5"><path d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z"></path><path d="M12 22V12"></path><polyline points="3.29 7 12 12 20.71 7"></polyline><path d="m7.5 4.27 9 5.15"></path></svg>
                        <span class="fw-semibold h5 mb-0">Order Items</span>
                    </div>

                    <% order.items.forEach((item) => { %>

                    <div class="border border-1 rounded-4 p-4 mt-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-4">
                                <div>
                                    <img src="<%= item.productImage %> " class="rounded-2" height="80" width="80">
                                </div>
                                <div>
                                    <p class="mb-2 fw-semibold"> <%= item.productName %> </p>
                                    <span class="text-muted">Quantity <%= item.quantity %> </span>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <% const itemStatus = item.orderStatus || 'pending'; %>
                                <span class="btn btn-sm rounded-2 item-status-badge <%= ['cancelled', 'return-requested', 'returned'].includes(itemStatus) ? 'btn-danger' : itemStatus === 'delivered' ? 'btn-success' : 'btn-light border' %>" data-item-id="<%= item._id %>"><%= itemStatus %></span>
                                <span class="fw-bold">₹<%= item.price %> </span>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                </div>

                <hr class="text-muted">
                <div class="my-4 d-flex justify-content-between gap-4">
                    <div class="w-100">
                        <div>
                            <span>Update Status</span>
                        </div>
                        <div class="mt-2">
                            <form action="/admin/orders/<%= order._id %>/update" method="get">
                                <label for="status" class="form-label small mb-0 ms-1">Order status</label>
                                <%
                                    const terminalStates = ["returned", "delivered", "cancelled", "return-requested"];
                                    const activeItem = order.items.find(item => !terminalStates.includes(item.orderStatus));
                                    const allTerminal = !activeItem;
                                    const currentStatus = activeItem ? activeItem.orderStatus : order.items[0].orderStatus;
                                %>
                                <select class="form-select mt-2" name="status" id="status" <%= allTerminal ? 'disabled' : '' %> >
                                    <option value="pending" <%= currentStatus === "pending" ? 'selected' : '' %> >Pending</option>
                                    <option value="processing" <%= currentStatus === "processing" ? 'selected' : '' %> >Processing</option>
                                    <option value="shipped" <%= currentStatus === "shipped" ? 'selected' : '' %> >Shipped</option>
                                    <option value="delivered" <%= currentStatus === "delivered" ? 'selected' : '' %> >Delivered</option>
                                </select>
                                <button type="submit" class="btn btn-primary mt-4 w-100" <%= allTerminal ? 'disabled' : '' %>>Save Changes</button>
                            </form>
                        </div>
                    </div>
                    <div class="w-100">
                        <div>
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-credit-card w-5 h-5"><rect width="20" height="14" x="2" y="5" rx="2"></rect><line x1="2" x2="22" y1="10" y2="10"></line></svg>
                            <span>Payment Summary</span>
                        </div>
                        <div class="p-4 rounded-4 mt-2" style="background-color: #f9fafb;">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Subtotal</span>
                                <span class="fw-semibold">₹<%= order.subtotal %> </span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Shipping</span>
                                <span class="fw-semibold">₹<%= order.shipping %> </span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>GST</span>
                                <span class="fw-semibold">₹<%= order.GST %> </span>
                            </div>
                            <% if (order.discount > 0) { %>
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Discount</span>
                                    <span class="fw-semibold text-danger"> -₹<%= order.discount %></span>
                                </div>
                            <% } %>
                            <hr class="text-muted">
                            <div class="d-flex justify-content-between">
                                <span class="fw-bold">Total</span>
                                <span class="text-primary fw-bold">₹<%= order.total %> </span>
                            </div>
                            <hr class="text-muted">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Payment Method</span>
                                <% if (order.paymentMethod === "cod") { %>
                                    <span class="fw-semibold">Cash on Delivery</span>
                                <% } else { %>
                                    <span class="fw-semibold"> <%= order.paymentMethod %> </span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>


    <div class="modal fade" id="returnModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <h5 class="modal-title">Process Return</h5>
                    <button class="btn btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form action="/admin/orders/<%= order._id %>/approve-return" method="POST" id="admin-return-form" data-id="<%= order._id %>">
                    <div class="modal-body">
                        <%= console.log(order._id) %>
                        <% const returnItems = order.items.filter(item => item.orderStatus === "return-requested"); %>
                        <% returnItems.forEach((item, i) => { %>
                            <div class="border rounded-2 p-3 mb-3">
                                <label for="product-<%= i %>" class="d-flex justify-content-between align-items-center gap-3 mb-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <input type="checkbox" name="product" value="<%= item._id %>" data-price="<%= item.price %>" id="product-<%= i %>" class="form-check-input mt-0">
                                        <div class="user-select-none"><%= item.productName %></div>
                                        <img src="<%= item.productImage %>" class="rounded-2 object-fit-cover" height="60" width="50">
                                    </div>
                                    <span>₹<%= item.price %></span>
                                </label>
                                
                                <div class="bg-light p-2 mt-2 rounded-2 small text-muted">
                                    <span class="fw-semibold text-dark">Reason:</span> <%= item.returnReason || 'Not specified' %>
                                </div>
                            </div>
                        <% }) %>

                        <div class="pt-2">
                            <label for="admin-note" class="form-label">Internal Admin Note(Optional)</label>
                            <input type="text" name="admin-note" id="admin-note" class="form-control" placeholder="Eg: Item was inspected">
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-light border rounded-2" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" id="refund-btn" class="btn btn-primary" disabled>Approve & Refund</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="toast-container position-fixed top-0 end-0 px-3 pt-5 mt-5">
        <div id="actionToast" class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body d-flex gap-2 align-items-center fw-bold">
                    <svg id="toast-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" height="20" width="20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"></path></svg>

                    <div id="actionToastBody">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/scripts/orderProcessing.js"></script>
</body>
</html>
