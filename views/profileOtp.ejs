<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>LUXE</title>
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
            crossorigin="anonymous"
        />
        <script
            src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"
        ></script>
        <link rel="stylesheet" href="/styles/register.css" />
        <script defer src="/scripts/otp.js"></script>
    </head>
    <body>
        <div class="container d-flex justify-content-center align-items-center min-vh-100">
            <div class="border shadow-sm w-50 rounded-4 form-container">
                <div class="text-center mt-4">
                    <h2 class="py-2 fw-bold" style="color: black; font-family: serif">LUXE</h2>
                    <h4 class="fw-semibold">Verify Your Email</h4>
                </div>
                <p class="text-center mb-0 mt-1 text-danger" style="visibility: <%= locals.error ? 'visible' : 'hidden' %>;"><%= locals.error || 'Placeholder' %></p>
                <form action="/profile/verify-email-otp" method="post" class="d-flex flex-column align-items-center py-2 mt-4" id="otpForm">
                    <label class="form-label fw-bold">Enter the 4-digit verification code</label>
                    
                    <div class="d-flex justify-content-center gap-3 mt-4 mb-2">
                        <input type="text" maxlength="1" inputmode="numeric" class="form-control text-center otp-input">
                        <input type="text" maxlength="1" inputmode="numeric" class="form-control text-center otp-input">
                        <input type="text" maxlength="1" inputmode="numeric" class="form-control text-center otp-input">
                        <input type="text" maxlength="1" inputmode="numeric" class="form-control text-center otp-input">
                    </div>

                    <input type="hidden" name="otp" id="combinedOtp">

                    <button class="btn text-white my-4 btn-main w-50" type="submit">Verify & Complete</button>
                </form>
                <form action="/auth/register/otp/resend" method="POST" class="d-flex justify-content-center align-items-center gap-1">
                    <p class="text-center mb-0">Didn't receive the code?</p>
                    <button type="submit" class="link btn py-0 px-0 text-decoration-none" id="resendBtn">Resend</button>
                </form>
                <p class="text-center py-4 timer-text">Resend available in <span id="countdown">0:00</span></p>
            </div>
        </div>

        <script>
            const secondsLeft = <%= secondsLeft %>
        </script>
    </body>
</html>
