<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LUXE</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/styles/navbar.css" />
    <link rel="stylesheet" href="/styles/checkout.css">
</head>
<body style="background-color: #fefbf8;">
    <%- include('partials/navbar.ejs') %>
    
    <div class="container-xxl mt-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a class="text-decoration-none" href="/">Home</a></li>
                <li class="breadcrumb-item"><a class="text-decoration-none" href="/cart">Cart</a></li>
                <li class="breadcrumb-item active" aria-current="page">checkout</li>
            </ol>
        </nav>
        <h2 class="fw-bold mt-2">Checkout</h2>
        <div class="d-flex flex-column align-items-center align-items-xl-start flex-xl-row gap-2 gap-lg-4 mt-4">
            <div class="w-100">
                <div class="border border-1 bg-white rounded-4 p-4">
                    <div>
                        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center mb-4">
                            <div class="mb-4">
                                <span class="fw-semibold">Shipping Address</span>
                            </div>
                            <div class="d-flex gap-4">
                                <% if (locals.defaultAddress) { %>
                                    <button class="btn btn-light border border-1 rounded-2" data-bs-toggle="modal" data-bs-target="#changeAddress">
                                        Change
                                    </button>
                                <% } %>
                                <button class="btn btn-light border border-1 rounded-2 d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#addressModal">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus h-4 w-4 mr-1" aria-hidden="true"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg>
                                    Add New
                                </button>
                            </div>
                        </div>
                        <% if (locals.defaultAddress) { %>
                        <input type="hidden" id="selectedAddressId" value="<%= defaultAddress._id %>">
                        <div class="border border-1 rounded-4 p-4 bg-white" id="address-display">
                            <div>
                                <p class="fw-semibold mb-2 h5" id="display-name"><%= defaultAddress.fullName %></p>
                                <p class="mb-1" id="display-phone"><%= defaultAddress.phone %></p>
                                <p class="mb-1" id="display-address"><%= defaultAddress.houseNumber %>, <%= defaultAddress.street %></p>
                                <p class="mb-0" id="display-region"><%= defaultAddress.state %>, <%= defaultAddress.pincode %></p>
                            </div>
                        </div>
                        <% } else { %>
                            <div class="text-center pt-2">
                                <div>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin mx-auto h-12 w-12 mb-3 opacity-50" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path><circle cx="12" cy="10" r="3"></circle></svg>
                                    <p class="text-muted">No saved Address available</p>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
                <div class="border border-1 bg-white rounded-4 p-4 mt-4">
                    <p class="h5 fw-bold">Payment Method</p>
                    <div class="border border-1 p-4 bg-white rounded-4">
                        <span class="fw-semibold mb-3">Payment Method</span>
                        <div class="mt-3">
                            <div class="mb-2 form-check">
                                <input type="radio" class="form-check-input" name="paymentMethod" id="credit">
                                <label for="credit" class="form-check-label">Credit/Debit Card</label>
                            </div>
                            <div class="mb-2 form-check">
                                <input type="radio" class="form-check-input" name="paymentMethod" id="upi">
                                <label for="upi" class="form-check-label">UPI / Gpay</label>
                            </div>
                            <div class="form-check">
                                <input type="radio" class="form-check-input" name="paymentMethod" id="cod">
                                <label for="cod" class="form-check-label">Cash on Delivery</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="w-50">

                <div class="border rounded-4 px-4 pt-5 pb-4 bg-white mb-3">
                    <h5>
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                            fill="none" stroke="currentColor" stroke-width="2"
                            stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"></path>
                            <circle cx="7.5" cy="7.5" r=".5" fill="currentColor"></circle>
                        </svg>
                        Coupon Code
                    </h5>
                    <form class="d-flex gap-3 mt-2" id="coupon-form">
                        <input type="text" class="form-control" name="coupon" placeholder="Enter code" />
                        <button type="submit" class="btn btn-danger">Apply</button>
                    </form>
                    <p class="mt-2 text-muted small">Try: CODE10</p>
                </div>

                <div class="border border-1 rounded-4 p-4 bg-white h-100 order-summary-card">
                    <h6 class="fw-bold mb-3">Order Summary</h6>
                    <% products.forEach((item) => { %>
                    <div class="d-flex justify-content-between mb-2">
                        <span class=""> <%= item.productName %> × <span> <%= item.quantity %> </span> </span>
                        <span> <%= item.price %> </span>
                    </div>
                    <% }); %>
                    <hr class="text-muted">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal</span>
                        <span>₹<%= data.subtotal %> </span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>GST</span>
                        <span>₹<%= data.gst %> </span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Shipping</span>
                        <span>₹<%= data.shipping %></span>
                    </div>
                    <hr class="text-secondary">
                    <div class="d-flex justify-content-between">
                        <span class="fw-bold h5">Total</span>
                        <span class="fw-bold h5">₹<%= data.total %></span>
                    </div>
                    <button class="btn btn-danger w-100 mt-4" id="place-order-btn">Place Order</button>
                </div>
            </div>

        </div>
    </div>


    <div class="modal fade" id="addressModal" tabindex="1" aria-hidden="true"> 
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content p-2">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Add New Address</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <form action="/checkout/add-address" class="form" method="POST" id="address">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="fullName" class="form-label">Full Name</label>
                            <input type="text" class="form-control" name="fullName" id="fullName" placeholder="full name">
                            <div class="error-container">
                                <p class="text-danger mb-0 small" id="name-error"></p>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="phone" class="form-label">Mobile Number</label>
                            <input type="text" class="form-control" name="phone" id="mobile" placeholder="phone" minlength="10">
                            <div class="error-container">
                                <p class="text-danger small mb-0" id="mobile-error"></p>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="pincode">Pincode</label>
                            <input type="text" class="form-control" name="pincode" id="pincode" placeholder="pincode">
                            <div class="error-container">
                                <p class="text-danger small mb-0 mt-1 pincode-error" id="pincode-error"></p>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="house" class="form-label">House No / Building / Apartment</label>
                            <input type="text" class="form-control" name="house" id="house" placeholder="Building name, House No">
                            <div class="error-container">
                                <p class="text-danger mb-0 mt-1" id="house-error"></p>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="street" class="form-label">Street</label>
                            <input type="text" class="form-control" name="street" id="street" placeholder="Street">
                            <div class="error-container">
                                <p class="text-danger mb-0 small street-error" id="street-error"></p>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="city" class="form-label">Town / City</label>
                            <input type="text" class="form-control" name="city" id="city" placeholder="city">
                        </div>
                        <div class="mb-3">
                            <label for="state" class="form-label">State</label>
                            <input type="text" class="form-control" name="state" id="state" placeholder="state">
                            <div class="error-container">
                                <p class="text-danger mb-0 small state-error" id="city-error"></p>
                            </div>
                        </div>
                        <div class="form-check mb-3">
                            <input type="checkbox" class="form-check-input" name="isDefault">
                            <label for="isDefault">save this for future orders</label>
                        </div>
                    </div>

                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" id="address-submit" class="btn btn-danger px-5">Add Address</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="changeAddress" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title fs-5">Select Shipping Address</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form action="">
                    <div class="modal-body">
                    <% locals.address.forEach((add, index) => { %>
                        <label class="d-flex align-items-start gap-3 border border-1 rounded-4 p-4 my-4 mx-0 mx-md-4" style="cursor: pointer;" for="address-<%= index %>">
                            <input type="radio" name="address" id="address-<%= index %>" class="form-check-input mt-1"
                                value="<%= add._id %>"
                                data-fullname="<%= add.fullName %>"
                                data-phone="<%= add.phone %>"
                                data-house="<%= add.houseNumber %>"
                                data-street="<%= add.street %>"
                                data-state="<%= add.state %>"
                                data-pincode="<%= add.pincode %>"
                                <%= (locals.defaultAddress && add._id.toString() === defaultAddress._id.toString()) ? 'checked' : '' %>>
                            <div>
                                <p class="mb-1 fw-semibold"><%= add.fullName %></p>
                                <p class="mb-1 text-muted"><%= add.phone %></p>
                                <p class="mb-1"><%= add.houseNumber %>, <%= add.street %></p>
                                <p class="mb-0"><%= add.state %>, <%= add.pincode %></p>
                                <% if (add.isDefault) { %>
                                    <span class="badge bg-danger mt-2">Default</span>
                                <% } %>
                            </div>
                        </label>
                    <% }); %>
                    </div>

                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" id="confirmAddress" class="btn btn-danger">Continue</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include('partials/footer.ejs') %>

    <div class="toast-container position-fixed top-0 end-0 px-3 pt-5 mt-5">
        <div id="actionToast" class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body d-flex gap-2 align-items-center fw-bold">
                    <svg id="toast-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" height="20" width="20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"></path></svg>

                    <div id="actionToastBody">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/scripts/checkout.js"></script>
</body>
</html>
