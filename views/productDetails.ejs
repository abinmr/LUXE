<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LUXE</title>
    <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
            crossorigin="anonymous"
            />
    <script
            src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"
        ></script>
    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
        integrity="sha384-tViUnnbYAV00FLIhhi3v/dWt3Jxw4gZQcNoSCxCIFNJVCx7/D55/wXsrNIRANwdD"
        crossorigin="anonymous"
    />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/drift-zoom@1.5.1/dist/drift-basic.min.css">
    <link rel="stylesheet" href="/styles/navbar.css" />
    <link rel="stylesheet" href="/styles/product.css">
    <script src="https://cdn.jsdelivr.net/npm/drift-zoom@1.5.1/dist/Drift.min.js"></script>
</head>
<body>
    <%- include('partials/navbar.ejs'), { categories } %>


    <div class="container-lg mt-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/home">Home</a></li>
                <li class="breadcrumb-item"><a href="/category/<%= product.category._id %>"> <%= product.category.name %> </a></li>
                <li class="breadcrumb-item active" aria-current="page"> <%= product.name %> </li>
            </ol>
        </nav>
        <div class="d-flex flex-column flex-lg-row gap-5 pb-4 pt-2">

            <div class="d-flex flex-column justify-content-center align-items-start">
                <div class="overflow-hidden rounded-3 img-fluid main-img" style="height: 800px; max-width: 650px;">
                    <img id="mainImage" 
                    src="<%= product.variants[0].images[0] %>" 
                    data-zoom="<%= product.variants[0].images[0] %>"
                    alt="Product Image" 
                    class="object-fit-cover img-fluid h-100 main-1">
                </div>
                <div id="thumbnailContainer"></div>
                <div id="detail"></div>
            </div>

            <div class="flex-grow-1">
                <h3><%= product.name %></h3>
                <p class="fw-bold fs-5">
                    ₹<span id="displayPrice"><%= product.variants[0].sizes[0].price %></span>
                    <span id="displayCompareAtPrice" class="text-muted text-decoration-line-through fs-6">
                        <% if (product.variants[0].sizes[0].compareAtPrice) { %>
                            ₹<%= product.variants[0].sizes[0].compareAtPrice %>
                        <% } %>
                    </span>
                </p>
                <p class="text-muted"><%= product.description %></p>

                <form action="/cart/add" method="POST" class="cart-form">
                    <input type="hidden" name="productId" id="inputProductId" value="<%= product._id %>">
                    <input type="hidden" name="variantId" id="inputVariantId" value="<%= product.variants[0]._id %>">
                    <input type="hidden" name="sizeId" id="inputSizeId" value="<%= product.variants[0].sizes[0]._id %>">

                    <div class="mt-4">
                        <label class="fw-bold">Size</label>
                        <div class="d-flex gap-3 mt-2" id="sizeContainer"></div>
                    </div>

                    <div class="mt-4">
                        <label class="fw-bold">Color</label>
                        <div class="d-flex align-items-center gap-3 mt-2">
                            <% product.variants.forEach((variant, index) => { %>
                                <button type="button"
                                    class="btn btn-light btn-color border-2
                                        <%= index === 0 ? 'border-danger' : 'border-light-subtle' %> px-4"
                                    data-variant-id="<%= variant._id %>"
                                    onclick="selectColor(this, '<%= variant._id %>')">
                                    <%= variant.color %>
                                </button>
                            <% }) %>
                        </div>
                    </div>

                    <div class="mt-4">
                        <label for="quantity" class="fw-bold">Quantity</label>
                        <div class="d-flex align-items-center gap-3 mt-2">
                            <select class="form-select shadow-none border-secondary-subtle w-auto" name="quantity" id="quantitySelect"></select>
                            <span id="stockBadge" class="text-muted small"></span>
                        </div>
                    </div>

                    <div class="mt-4">
                        <div class="mb-3 d-flex gap-3">
                            <button type="submit" value="cart" class="btn btn-danger w-100 d-flex justify-content-center align-items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"></circle><circle cx="19" cy="21" r="1"></circle><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path></svg>
                                Add to Cart
                            </button>
                            <% const isInWishlist = locals.userWishlist.includes(product._id.toString()) %>
                            <% if (isInWishlist) {%>
                                <button data-item-id="<%= product._id %>" class="btn border glass text-dark rounded-2 text-decoration-none wishlistRemove-btn" aria-label="Add to wishlist">
                                    <i class="bi bi-heart-fill text-danger fs-5"></i>
                                </button>
                            <% } else { %>
                                <button data-item-id="<%= product._id %>" class="btn border glass text-dark rounded-2 text-decoration-none wishlistAdd-btn" aria-label="Add to wishlist">
                                    <i class="bi bi-heart fs-5"></i>
                                </button>
                            <% } %>
                        </div>
                        <button type="submit" formaction="/checkout/buy-now/" class="btn btn-light border-light-subtle w-100 d-flex justify-content-center align-items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                            Buy Now
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="mt-5">
            <h4 class="fw-bold mb-4">You might also like</h4>
            <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 gap-0">
                <% otherProducts.forEach((product) => { %>
                    <% 
                       const price = product.variants[0].sizes[0].price;
                       const comparePrice = product.variants[0].sizes[0].compareAtPrice;
                       let discount = 0;
                       if (comparePrice > price) {
                           discount = Math.round(((comparePrice - price) / comparePrice) * 100);
                       }
                    %>
                    <div class="col mb-4">
                        <div class="card h-100 border rounded-3 overflow-hidden shadow-sm" style="background-color: #f6f6f6;">
                            
                            <div class="position-relative">
                                <a href="/product/<%= product._id %>" class="text-decoration-none d-block overflow-hidden" style="height: 400px;">
                                    <img src="<%= product.variants[0].images[0] %>" 
                                         alt="<%= product.name %>" 
                                         class="card-img-top object-fit-cover w-100 h-100 img-animation" 
                                         style="border-bottom: 1px solid #eaeaea;">
                                </a>
                                
                                <% if (discount > 0) { %>
                                    <span class="position-absolute top-0 start-0 badge bg-danger m-3 py-1 px-2 rounded-1 fw-medium">
                                        -<%= discount %>%
                                    </span>
                                <% } %>

                                <% const isInWishlist = locals.userWishlist.includes(product._id.toString()) %>
                                <% if (isInWishlist) {%>
                                    <button data-item-id="<%= product._id %>" class="btn glass text-dark position-absolute top-0 end-0 m-2 rounded-circle text-decoration-none wishlistRemove-btn" aria-label="Add to wishlist">
                                        <i class="bi bi-heart-fill text-danger fs-5"></i>
                                    </button>
                                <% } else { %>
                                    <button data-item-id="<%= product._id %>" class="btn glass text-dark position-absolute top-0 end-0 m-2 rounded-circle text-decoration-none wishlistAdd-btn" aria-label="Add to wishlist">
                                        <i class="bi bi-heart fs-5"></i>
                                    </button>
                                <% } %>
                            </div>

                            <div class="card-body d-flex flex-column p-3">
                                <h6 class="card-title fw-semibold text-truncate mb-1" title="<%= product.name %>">
                                    <%= product.name %>
                                </h6>
                                
                                <div class="mb-3 d-flex align-items-center gap-2">
                                    <span class="fw-bold fs-5 mb-0 text-dark">₹<%= price %></span>
                                    <% if (comparePrice > price) { %>
                                        <span class="text-decoration-line-through text-muted fw-normal" style="font-size: 0.85rem;">
                                            ₹<%= comparePrice %>
                                        </span>
                                    <% } %>
                                </div>

                                <form action="/cart/add" method="POST" class="mt-auto cart-form">
                                    <input type="hidden" name="productId" value="<%= product._id %>">
                                    <input type="hidden" name="variantId" value="<%= product.variants[0]._id %>">
                                    <input type="hidden" name="sizeId" value="<%= product.variants[0].sizes[0]._id %>">
                                    <input type="hidden" name="quantity" value="1">
                                    
                                    <button value="cart" class="btn btn-danger w-100 rounded-2 fw-medium d-flex align-items-center justify-content-center gap-2 py-2" style="background-color: #c94646; border-color: #c94646;">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shopping-cart"><circle cx="8" cy="21" r="1"></circle><circle cx="19" cy="21" r="1"></circle><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path></svg>
                                        Add to Cart
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>

    <%- include("partials/footer.ejs") %>

        <div class="toast-container position-fixed bottom-0 end-0 p-3 m-2">
            <div id="actionToast" class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body d-flex gap-2 align-items-center fw-bold">
                        <svg id="toast-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" height="20" width="20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"></path></svg>

                        <div id="actionToastBody">
                        </div>
                    </div>
                </div>
            </div>
        </div>

    <script>
        const productData = <%- JSON.stringify(product) %>;
    </script>
    <script src="/scripts/productDetails.js"></script>
</body>
</html>
