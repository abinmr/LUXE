<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
        <script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <title>LUXE</title>
        <link rel="stylesheet" href="/styles/admin-nav.css" />
    </head>
    <body style="background-color: #f9fafb;">

        <%- include('partials/admin-header.ejs', { activePage: 'categories' }) %>
        <div class="my-4 mx-5">
            <div class="d-flex mb-4">
                <a href="/admin/categories" class="btn btn-light border-0 me-3" style="align-self: center;" >
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class=""><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
                </a>
                <div>
                    <h2>Add New Category</h2>
                    <p class="mb-0 text-muted">Create a new Category to organize the products</p>
                </div>
            </div>

            <form action="/admin/categories/add" method="POST" enctype="multipart/form-data">
                <div class="p-4 border rounded-4 bg-white">
                    <h5 class="mb-3">Category Details</h5>
                    <div class="error-container text-center text-danger">
                        <p class="mb-0 fw-semibold"> <%= locals.categoryError %></p>
                    </div>
                    <div class="mb-2">
                        <label for="category-name" class="form-label">Category Name</label>
                        <input type="text" class="form-control" name="categoryName" id="categoryName" placeholder="category name" required>
                        <div class="error-container text-danger">
                            <p class="mb-0 fw-semibold"> <%= locals.nameError %> </p>
                        </div>
                    </div>
                    <div class="mb-2">
                        <label for="slug" class="form-label">Slug</label>
                        <input type="text" class="form-control" name="slug" id="slug" placeholder="slug">
                        <div class="error-container text-danger">
                            <p class="mb-0 fw-semibold"> <%= locals.slugError %> </p>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <input type="text" class="form-control" name="description" id="description" placeholder="description" required>
                    </div>
                    <div class="mb-3">
                        <label for="image" class="form-label">Image</label>
                        <input type="file" accept=".png, .jpg, .webp" class="form-control" name="image" id="image">
                    </div>
                    <div class="mb-3">
                        <img id="preview" src="" alt="Image preview" class="img-fluid rounded-2 d-none" style="max-height: 200px;">
                    </div>
                    <div class="mb-2 form-check">
                        <label for="active" class="form-check-label">Set as Active</label>
                        <input type="checkbox" class="form-check-input" name="active" id="isActive">
                    </div>
                </div>
                    <div class="mt-4 d-flex justify-content-end gap-4">
                        <a href="/admin/categories/" class="btn btn-light border rounded-3">Cancel</a>
                        <button type="submit" class="btn btn-primary rounded-3">Create Category</button>
                    </div>
            </form>
        </div>
        <%- include('partials/admin-footer.ejs') %>
        <script>
            const imageInput = document.getElementById('image');
            const preview = document.getElementById('preview');

            imageInput.addEventListener('change', function () {
                const file = this.files[0];

                if (file) {
                    const reader = new FileReader();

                    reader.addEventListener('load', function () {
                        preview.src = this.result;
                        preview.classList.remove('d-none'); // show image
                    });

                    reader.readAsDataURL(file);
                } else {
                    preview.src = "";
                    preview.classList.add('d-none'); // hide if no file
                }
            });
        </script>
    </body>
</html>
