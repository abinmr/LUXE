<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <link href="https://unpkg.com/cropperjs@1.6.2/dist/cropper.css" rel="stylesheet"/>
        <script src="https://unpkg.com/cropperjs@1.6.2/dist/cropper.js"></script>
        <title>LUXE</title>
        <link rel="stylesheet" href="/styles/admin-nav.css" />
        <link rel="stylesheet" href="/styles/adminCategory.css">
    </head>
    <body style="background-color: #f9fafb;">

        <%- include('partials/admin-header.ejs', { activePage: 'categories' }) %>
        <div class="my-4 mx-5">
            <div class="d-flex mb-4">
                <a href="/admin/categories" class="btn btn-light border-0 me-3" style="align-self: center;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
                </a>
                <div>
                    <h2>Add New Category</h2>
                    <p class="mb-0 text-muted">Create a new Category to organize the products</p>
                </div>
            </div>

            <form action="/admin/categories/add" method="POST" enctype="multipart/form-data" id="form">
                <div class="p-4 border rounded-4 bg-white">
                    <h5 class="mb-3">Category Details</h5>

                    <div class="error-container text-center text-danger">
                        <p class="mb-0 fw-semibold" style="font-size: 18px;"><%= locals.categoryError %></p>
                    </div>

                    <div class="mb-1">
                        <label for="categoryName" class="form-label">Category Name</label>
                        <input type="text" class="form-control text-capitalize" name="categoryName" id="categoryName" placeholder="Category name" value="<%= locals.categoryName || '' %>" >
                        <div class="error-container text-danger mt-1">
                            <p class="mb-0 small fw-semibold" id="categoryNameError"><%= locals.nameError %></p>
                        </div>
                    </div>

                    <div class="mb-1">
                        <label for="slug" class="form-label">Slug</label>
                        <input type="text" class="form-control" name="slug" id="slug" placeholder="slug" value="<%= locals.slug || '' %>">
                        <div class="error-container text-danger mt-1">
                            <p class="mb-0 small fw-semibold"><%= locals.slugError %></p>
                        </div>
                    </div>

                    <div class="mb-1">
                        <label for="description" class="form-label">Description</label>
                        <input type="text" class="form-control" name="description" id="description" placeholder="Description" value="<%= locals.description || '' %>" >
                        <div class="error-container">
                            <p class="text-danger mb-0 small fw-semibold" id="descError"></p>
                        </div>
                    </div>

                    <div class="mb-1">
                        <label class="form-label">Image</label>
                        <div class="image-picker-area" id="imagePickerArea">
                            <div id="previewContainer"></div>
                            <button type="button" class="btn btn-light border btn-sm d-flex align-items-center gap-1" id="addImageBtn">
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg>
                                Choose Image
                            </button>
                            <div id="hiddenInputContainer"></div>
                            <input type="file" id="triggerInput" class="d-none" accept=".png,.jpg,.webp">
                        </div>
                        <div class="error-container mt-1">
                            <p class="text-danger mb-0 small fw-semibold" id="image-error"><%= locals.imageError %></p>
                        </div>
                    </div>

                    <div class="mb-2 form-check">
                        <label for="isActive" class="form-check-label">Set as Active</label>
                        <input type="checkbox" class="form-check-input" name="active" id="isActive">
                    </div>
                </div>

                <div class="mt-4 d-flex justify-content-end gap-4">
                    <a href="/admin/categories/" class="btn btn-light border rounded-3">Cancel</a>
                    <button type="submit" id="add-category-btn" class="btn btn-primary rounded-3">Create Category</button>
                </div>
            </form>
        </div>
        <%- include('partials/admin-footer.ejs') %>

        <div class="modal fade" id="cropModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h6 class="modal-title">Crop Image</h6>
                    </div>
                    <div class="modal-body">
                        <div class="img-container">
                            <img id="cropImg" src="" alt="">
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-sm" id="cropCancelBtn">Cancel</button>
                        <button type="button" class="btn btn-primary btn-sm"   id="cropConfirmBtn">Crop →</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="resultModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h6 class="modal-title">Cropped Result</h6>
                    </div>
                    <div class="modal-body text-center p-3">
                        <img id="resultImg" src="" alt="Cropped">
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-sm" id="resultRetryBtn">← Re-crop</button>
                        <button type="button" class="btn btn-primary btn-sm"   id="resultUseBtn">Use Image</button>
                    </div>
                </div>
            </div>
        </div>

        <script src="/scripts/adminCategory.js"></script>
    </body>
</html>
