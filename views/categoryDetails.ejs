<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>LUXE</title>
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
            crossorigin="anonymous"
        />
        <script defer
            src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"
        ></script>
        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
            integrity="sha384-tViUnnbYAV00FLIhhi3v/dWt3Jxw4gZQcNoSCxCIFNJVCx7/D55/wXsrNIRANwdD"
            crossorigin="anonymous"
        />
        <link rel="stylesheet" href="/styles/navbar.css" />
        <link rel="stylesheet" href="/styles/categoryDetails.css">
        <script defer src="/scripts/home.js"></script>
    </head>
    <body>
<%- include('partials/navbar.ejs', { categories }) %>
    <% const category = categories.find((cat) => String(cat._id) === String(id)) %>
    
    <div class="container-xxl mt-5">
            
            <div class="d-flex justify-content-between">
                <div>
                    <h1 class="fw-bolder mb-1 category-name"> <%= category.name %> </h1>
                    <p class="text-muted mb-4 d-none d-sm-block"> <%= products.length %> products</p>
                </div>
                <div class="d-flex gap-1 gap-lg-3">
                    <div class="d-lg-none">
                        <button type="button" class="btn btn-light btn-sm border filter-btn" data-bs-toggle="offcanvas" data-bs-target="#offcanvasFilter" aria-labelledby="filterMenu" style="background-color: white;"><img src="/images/filter.svg" alt=""> Filter</button>
                    </div>
                    <div class="d-flex justify-content-end mb-4">
                        <form action="">
                            <select name="filter" id="filter" class="form-select form-select-sm w-auto">
                                <option value="featured">Latest</option>
                                <option value="low-to-high">Price: Low to High</option>
                                <option value="high-to-low">Price: High to Low</option>
                                <option value="A-Z">Sort: A-Z</option>
                                <option value="Z-A">Sort: Z-A</option>
                            </select>
                        </form>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-4">
                <div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvasFilter" aria-labelledby="filterMenuLabel">
                    <div class="offcanvas-header">
                        <h5 class="offcanvas-title">Filter</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                    </div>
                    <div class="offcanvas-body">
                        <form action="/categories" class="w-100" id="mobileFilterForm">
                            <h6 class="fw-bold mb-3">Price Range</h6>
                            <div class="position-relative mb-4">
                                <input type="range" class="form-range" min="0" max="500" step="10" name="priceRange" id="priceRangeMobile" value="500">
                                <div class="d-flex justify-content-between text-muted small mt-1">
                                    <span>₹0</span>
                                    <span id="maxRangeMobile">₹500</span>
                                </div>
                            </div>

                            <div class="mt-4 mb-4">
                                <h6 class="fw-bold mb-3">Size</h6>
                                <div class="d-flex flex-column gap-2">
                                    <% ['XS', 'S', 'M', 'L', 'XL', 'XXL'].forEach(size => { %>
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" name="size" id="size-<%= size.toLowerCase() %>-mobile" value="<%= size %>">
                                        <label for="size-<%= size.toLowerCase() %>-mobile" class="form-check-label text-black"><%= size %></label>
                                    </div>
                                    <% }) %>
                                </div>
                            </div>

                            <div class="mt-4 mb-4">
                                <h6 class="fw-bold mb-3">Color</h6>
                                <div class="d-flex flex-column gap-2">
                                    <% colors.forEach(color => { %>
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" name="color" id="color-<%= color.toLowerCase() %>-mobile" value="<%= color %>">
                                        <label for="color-<%= color.toLowerCase() %>-mobile" class="form-check-label text-black"><%= color %></label>
                                    </div>
                                    <% }) %>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

            <aside class="col-md-3 pb-5 d-none d-lg-block">
                <form action="/categories" class="" id="desktopFilterForm">
                    <h6 class="fw-bold mb-3">Price Range</h6>
                    <div class="position-relative mb-4">
                        <input type="range" class="form-range" min="0" max="500" step="10" name="priceRange" id="priceRangeDesktop" value="500">
                        <div class="d-flex justify-content-between text-muted small mt-1">
                            <span>₹0</span>
                            <span id="maxRangeDesktop">₹500</span>
                        </div>
                    </div>

                    <div class="mt-4 mb-4">
                        <h6 class="fw-bold mb-3">Size</h6>
                        <div class="d-flex flex-column gap-2">
                            <% ['XS', 'S', 'M', 'L', 'XL', 'XXL'].forEach(size => { %>
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="size" id="size-<%= size.toLowerCase() %>-desktop" value="<%= size %>">
                                    <label for="size-<%= size.toLowerCase() %>-desktop" class="form-check-label text-black"><%= size %></label>
                                </div>
                            <% }) %>
                        </div>
                    </div>

                    <div class="mt-4 mb-4">
                        <h6 class="fw-bold mb-3">Color</h6>
                        <div class="d-flex flex-column gap-2">
                            <% colors.forEach(color => { %>
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="color" id="color-<%= color.toLowerCase() %>-desktop" value="<%= color %>">
                                    <label for="color-<%= color.toLowerCase() %>-desktop" class="form-check-label text-black"><%= color %></label>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </form>
            </aside>

            <main class="flex-grow-1">
                <div class="row" id="product-grid">
                    <% products.forEach((product) => { %>
                    <% if (product.variants && product.variants.length > 0) { %>
                        <% 
                           // Calculate discount percentage for the badge
                           const price = product.variants[0].sizes[0].price;
                           const comparePrice = product.variants[0].sizes[0].compareAtPrice;
                           let discount = 0;
                           if (comparePrice > price) {
                               discount = Math.round(((comparePrice - price) / comparePrice) * 100);
                           }
                        %>

                        <div class="col-12 col-sm-6 col-md-6 col-xl-4 mb-4">
                            <div class="card h-100 border rounded-3 overflow-hidden shadow-sm" style="background-color: #f6f6f6;">
                                
                                <div class="position-relative">
                                    <a href="/product/<%= product._id %>" class="text-decoration-none d-block overflow-hidden" style="height: 400px;">
                                        <img src="<%= product.variants[0].images[0] %>" 
                                             alt="<%= product.name %>" 
                                             class="card-img-top object-fit-cover w-100 h-100 img-animation" 
                                             style="border-bottom: 1px solid #eaeaea;">
                                    </a>
                                    
                                    <% if (discount > 0) { %>
                                        <span class="position-absolute top-0 start-0 badge bg-danger m-3 py-1 px-2 rounded-1 fw-medium">
                                            -<%= discount %>%
                                        </span>
                                    <% } %>

                                    <% const isInWishlist = locals.userWishlist.includes(product._id.toString()) %>
                                    <% if (isInWishlist) {%>
                                        <button data-item-id="<%= product._id %>" class="btn glass text-dark position-absolute top-0 end-0 m-2 rounded-circle text-decoration-none wishlistRemove-btn" aria-label="Add to wishlist">
                                            <i class="bi bi-heart-fill text-danger fs-5"></i>
                                        </button>
                                    <% } else { %>
                                        <button data-item-id="<%= product._id %>" class="btn glass text-dark position-absolute top-0 end-0 m-2 rounded-circle text-decoration-none wishlistAdd-btn" aria-label="Add to wishlist">
                                            <i class="bi bi-heart fs-5"></i>
                                        </button>
                                    <% } %>
                                </div>

                                <div class="card-body d-flex flex-column p-3">
                                    <h6 class="card-title fw-semibold text-truncate mb-1" title="<%= product.name %>">
                                        <%= product.name %>
                                    </h6>
                                    
                                    <div class="mb-3 d-flex align-items-center gap-2">
                                        <span class="fw-bold fs-5 mb-0 text-dark">₹<%= price %></span>
                                        <% if (comparePrice > price) { %>
                                            <span class="text-decoration-line-through text-muted fw-normal" style="font-size: 0.85rem;">
                                                ₹<%= comparePrice %>
                                            </span>
                                        <% } %>
                                    </div>

                                    <form action="/cart/add" method="POST" class="mt-auto cart-form">
                                        <input type="hidden" name="productId" value="<%= product._id %>">
                                        <input type="hidden" name="variantId" value="<%= product.variants[0]._id %>">
                                        <input type="hidden" name="sizeId" value="<%= product.variants[0].sizes[0]._id %>">
                                        <input type="hidden" name="quantity" value="1">
                                        
                                        <button class="btn btn-danger w-100 rounded-2 fw-medium d-flex align-items-center justify-content-center gap-2 py-2" style="background-color: #c94646; border-color: #c94646;">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shopping-cart"><circle cx="8" cy="21" r="1"></circle><circle cx="19" cy="21" r="1"></circle><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path></svg>
                                            Add to Cart
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    <% } %>
                    <% }) %>
                </div>
            </main>
        </div>
    </div>
    
    <%- include('partials/footer.ejs') %>

        <div class="toast-container position-fixed bottom-0 end-0 p-3 m-2">
            <div id="actionToast" class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body d-flex gap-2 align-items-center fw-bold">
                        <svg id="toast-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" height="20" width="20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"></path></svg>

                        <div id="actionToastBody">
                        </div>
                    </div>
                </div>
            </div>
        </div>

    <script>
        window.categoryId = "<%= category._id %>";
    </script>
    <script src="/scripts/categoryDetails.js"></script>
    </body>
</html>
