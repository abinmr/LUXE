<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles/admin-nav.css">
    <link rel="stylesheet" href="/styles/customers.css">
    <title>Luxe</title>
</head>
<body>
    
    <%- include('partials/admin-nav.ejs') %>
    <main>
        <h2>Customers</h2>
        <p class="main-text">Manage registered users and customers accounts.</p>
        <div class="customers-cards">
            <div class="card">
                <p class="card-title">Total Customers</p>
                <h4 class="card-text">8</h4>
            </div>

            <div class="card">
                <p class="card-title">Active Customers</p>
                <h4 class="card-text active-customer">7</h4>
            </div>

            <div class="card">
                <p class="card-title">Blocked Customers</p>
                <h4 class="card-text blocked-customer">8</h4>
            </div>

            <div class="card">
                <p class="card-title">Total Revenue</p>
                <h4 class="card-text">₹34,200</h4>
            </div>

        </div>

        <div class="customer-form-container">
            <form action="/api/admin/customers/search" method="POST" class="customer-form">
                <div class="input-container">
                    <img src="/images/search.svg" alt="search button icon">
                    <input type="text" name="search" id="search">
                </div>
                <select name="status" id="status">
                    <button><selectedcontent></selectedcontent></button>
                    <option value="all-status">All Statuses</option>
                    <option value="Active">Active</option>
                    <option value="Blocked">Blocked</option>
                </select>
            </form>
        </div>

        <div class="table-container">
            <div class="table-header">
                <h2>All Customers (8)</h2>
            </div>
            
            <table class="customer-table">
                <thead>
                    <tr>
                        <th>Customer ID</th>
                        <th>Customer</th>
                        <th>Phone</th>
                        <th>Joined Date</th>
                        <th>Orders</th>
                        <th>Total Spent</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>CUS001</td>
                        <td>
                            <div class="customer-name">Priya Sharma</div>
                            <div class="customer-email">priya.sharma@email.com</div>
                        </td>
                        <td>+91 98765 43210</td>
                        <td>Jan 15, 2024</td>
                        <td>12</td>
                        <td>₹45,600</td>
                        <td><span class="badge active">Active</span></td>
                        <td class="actions">
                            <button class="action-btn">⋮</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>


    </main>
</body>
</html>
