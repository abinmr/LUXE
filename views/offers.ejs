<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>LUXE</title>
    <link rel="stylesheet" href="/styles/admin-nav.css">
</head>
<body>
    
    <%- include('partials/admin-header.ejs', { activePage: 'offers' }) %>
        <div class="m-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2>Offers</h2>
                    <p class="text-muted">Manage your promotional campaigns.</p>
                </div>
                <a href="/admin/offers/add">
                    <button class="btn btn-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus w-4 h-4 mr-2"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg>
                        Create Offer
                    </button>
                </a>
            </div>
            <div class="border border-1 rounded-4 p-4 mt-4 bg-white">
                <form action="/admin/offers" method="GET" class="d-flex align-items-center gap-4">
                    <div class="input-group flex-grow-1 focus-ring-wrapper rounded-3">
                        <span class="input-group-text border-0 text-muted" style="background-color: #f3f3f5;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
                        </span>
                        <input type="search" class="form-control border-0 shadow-none" name="search" id="search" value="<%= locals.search %>" placeholder="Search categories..." style="background-color: #f3f3f5">
                    </div>
                    <a href="/admin/categories/" class="btn btn-danger btn-sm rounded-2">Cancel</a>
                    <button type="submit" class="btn btn-primary btn-sm rounded-2">Submit</button>
                </form>
            </div>

            <div class="bg-white mt-4 px-3 py-4 border rounded-4" style="min-height: 500px; display: block; ">
                <div>
                    <h3 class="fs-5 ps-1">All Offers</h3>
                </div>
                <table class="table">
                    <thead>
                        <tr>
                            <th scope="col">Offers Details</th>
                            <th scope="col">Type</th>
                            <th scope="col">Validity</th>
                            <th scope="col">Status</th>
                            <th scope="col">Applicable</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    <% const options = { year: 'numeric', month: 'numeric', day: 'numeric' }; %>
                        <% offers.forEach((offer) => { %>
                            <tr class="offers" data-item-id="<%= offer._id %>">
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="<%= offer.image %>" alt="<%= offer.name %>" class="rounded-2" height="48" width="48">
                                        <div>
                                            <div><%= offer.title %></div>
                                            <div class="text-muted small text-truncate" style="width: 12rem;"><%= offer.description %></div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <% if (offer.offerType === "percentage") { %>
                                        <div class="">
                                            <button class="btn btn-light btn-sm border rounded-4">Percentage Discount</button>
                                            <span class="text-muted"><%= offer.discountPercentage %>%</span>
                                        </div>
                                    <% } %>
                                </td>
                                <td class="small">
                                    <div class="text-muted"><%= offer.startDate.toLocaleDateString('en-IN', options) %></div>
                                    <div class="text-body-tertiary">to</div>
                                    <div class="text-muted"><%= offer.endDate.toLocaleDateString('en-IN', options) %></div>
                                </td>
                                <td style="width: 280px;">
                                    <% if (offer.isActive) { %>
                                        <button class="btn btn-dark btn-sm rounded-3">Active</button>
                                    <% } else { %>
                                        <button class="btn btn-light btn-sm border rounded-3">InActive</button>
                                    <% } %>
                                    <% if (offer.featureHomepage) { %>
                                        <button class="btn btn-warning btn-sm rounded-3">Featured</button>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (offer.applicableTo === "all") { %>
                                        <span class="small">All Products</span>
                                    <% } else if (offer.applicableTo === "category") { %>
                                        <span class="small text-secondary-emphasis">Specific Categories</span>
                                    <% } else if (offer.applicableTo === "products") { %>
                                        <span>Specific Products</span>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <button class="btn btn-light rounded-2" data-bs-toggle="dropdown" aria-haspopup="true" data-bs-offset="70,5" aria-expanded="false">⋮</button>
                                        <ul class="dropdown-menu">
                                            <li class="dropdown-item">
                                                <a href="/admin/offers/edit/<%= offer._id %>" class="dropdown-item-text text-decoration-none small">
                                                    <img src="/images/edit.svg" alt="edit icon" class="me-2">
                                                    Edit
                                                </a>
                                            </li>
                                            <li class="dropdown-divider"></li>
                                            <li class="dropdown-item delete-btn" data-id="<%= offer._id %>">
                                                <span class="dropdown-item-text small text-danger">
                                                    <img src="/images/delete.svg" alt="trash icon" class="me-2">
                                                    Delete
                                                </span>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

    <%- include('partials/admin-footer.ejs') %>

    <div class="toast-container position-fixed top-0 end-0 px-3 mt-5">
        <div id="actionToast" class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body d-flex gap-2 align-items-center fw-bold">
                    <svg id="toast-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" height="20" width="20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"></path></svg>

                    <div id="actionToastBody">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/scripts/offers.js"></script>
</body>
</html>

