<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>LUXE</title>
    <link rel="stylesheet" href="/styles/admin-nav.css">
    <style>
        .error-container p {
            display: none;
        }
    </style>
</head>
<body>
    <%- include('partials/admin-header.ejs', { activePage: 'coupons' }) %>

        <div class="my-4 mx-5">
            <div class="d-flex mb-4">
                <a href="/admin/coupons" class="btn btn-light border-0 me-3" style="align-self: center;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
                </a>
                <div>
                    <h2>Create New Coupon</h2>
                    <p class="mb-0 text-muted">Create a new discount coupon for your customers</p>
                </div>
            </div>

            <form action="/admin/coupons/add" method="POST" id="coupon-form">
                <div class="p-4 border rounded-4 bg-white">
                    <h5 class="mb-0">Coupon Details</h5>

                    <div class="text-danger mb-1" style="min-height: 20px;">
                        <p class="mb-0 fw-semibold text-center"><%= locals.couponError %></p>
                    </div>
                    <div class="input-group gap-4">
                        <div class="col">
                            <label for="code" class="form-label">Coupon Code</label>
                            <input type="text" class="form-control" placeholder="eg, WELCOME10" value="<%= oldData.code || '' %>" name="code" id="code">
                            <div class="error-container text-danger">
                                <p class="mb-0 fw-semibold" id="codeError"></p>
                            </div>
                        </div>
                        <div class="col">
                            <label for="discount-type" class="form-label">Discount Type</label>
                            <select name="discountType" id="discount-type" class="form-select">
                                <option value="percentage" <%= oldData.discountType === "percentage" ? "selected" : '' %> >Percentage</option>
                                <option value="fixed" <%= oldData.discountType === "fixed" ? "selected" : '' %> >Fixed Amount</option>
                            </select>
                        </div>
                    </div>
                    <div class="my-2">
                        <label for="description" class="form-label">Description</label>
                        <input type="text" class="form-control" placeholder="describe coupon" value="<%= oldData.description || '' %>" name="description" id="description">
                        <div class="error-container text-danger">
                            <p class="mb-0 fw-semibold" id="descriptionError"></p>
                        </div>
                    </div>
                    <div class="input-group gap-4 mb-2">
                        <div class="col" id="discount-percentage-container">
                            <label for="discount-value-percentage" class="form-label">Discount Percentage (%)</label>
                            <input type="number" class="form-control" min="0" value="<%= oldData.discountValue || '' %>" placeholder="0" name="discountValue" id="discount-value-percentage">
                            <div class="error-container text-danger">
                                <p class="mb-0 fw-semibold" id="discount-percentage-error"></p>
                            </div>
                        </div>
                        <div class="col d-none" id="discount-fixed-container">
                            <label for="discount-value-fixed" class="form-label">Discount Amount</label>
                            <input type="number" class="form-control" min="0" value="<%= oldData.discountValue || '' %>" placeholder="0" name="discountValue" id="discount-value-fixed" disabled>
                            <div class="error-container text-danger">
                                <p class="mb-0 fw-semibold" id="discount-fixed-error"></p>
                            </div>
                        </div>
                        <div class="col">
                            <label for="min-purchase-amount" class="form-label">Min Purchase Amout</label>
                            <input type="number" class="form-control" value="<%= oldData.minPurchaseAmount || '' %>" name="minPurchaseAmount" placeholder="0" id="min-purchase-amount">
                            <div class="error-container text-danger">
                                <p class="mb-0 fw-semibold" id="min-purchase-error"></p>
                            </div>
                        </div>
                    </div>
                    <div class="input-group gap-4 mb-2">
                        <div class="col" id="max-discount-container">
                            <label for="max-discount" class="form-label">Max Discount (optional)</label>
                            <input type="number" class="form-control" value="<%= oldData.maxDiscount || '' %>" placeholder="0" min="1" name="maxDiscount" id="max-discount">
                            <div class="error-container text-danger">
                                <p class="mb-0 fw-semibold" id="max-discount-error"></p>
                            </div>
                        </div>
                        <div class="col">
                            <label for="usage-limit" class="form-label">Usage Limit</label>
                            <input type="number" class="form-control" placeholder="0" min="1" value="<%= oldData.usageLimit || '' %>" name="usageLimit" id="usage-limit">
                            <div class="error-container text-danger">
                                <p class="mb-0 fw-semibold" id="usage-limit-error"></p>
                            </div>
                        </div>
                    </div>
                    <div class="input-group gap-4 mb-2">
                        <div class="col">
                            <label for="start-date" class="form-label">Start Date</label>
                            <input type="date" class="form-control user-select-none" value="<%= oldData.startDate || '' %>" name="startDate" id="start-date">
                            <div class="error-container text-danger">
                                <p class="mb-0 fw-semibold" id="start-date-error"></p>
                            </div>
                        </div>
                        <div class="col">
                            <label for="end-date" class="form-label">Expiry Date</label>
                            <input type="date" class="form-control" value="<%= oldData.expiryDate || '' %>" name="expiryDate" id="expiry-date">
                            <div class="error-container text-danger">
                                <p class="mb-0 fw-semibold" id="expiry-date-error"></p>
                            </div>
                        </div>
                    </div>
                    <div class="">
                        <input type="checkbox" name="isActive" class="form-check-input" id="couponStatus" <%= oldData.isActive ? 'checked' : '' %> >
                        <label for="couponStatus">Set as Active</label>
                    </div>
                </div>

                <div class="d-flex justify-content-end align-items-center gap-4 mt-4">
                    <a href="/admin/coupons" class="btn btn-light border rounded-2">Cancel</a>
                    <button class="btn btn-primary rounded-2" id="coupon-btn">Create Coupon</button>
                </div>
            </form>
        </div>

        <script src="/scripts/adminCouponsAdd.js"></script>
</body>
</html>
