<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>LUXE</title>
    <link rel="stylesheet" href="/styles/admin-nav.css">
</head>
<body>
    
    <%- include('partials/admin-header.ejs', { activePage: 'coupons' }) %>
    <div class="m-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2>Coupons</h2>
                <p class="text-muted">Manage your product inventory</p>
            </div>
            <a href="/admin/coupons/add">
                <button class="btn btn-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus w-4 h-4 mr-2"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg>
                    Create Coupon
                </button>
            </a>
        </div>

        <div class="border border-1 rounded-4 p-4 mt-4 bg-white">
            <form action="/admin/coupons" method="GET" id="searchForm" class="d-flex align-items-center gap-2">
                <div class="input-group flex-grow-1 focus-ring-wrapper me-2 rounded-3">
                    <span class="input-group-text border-0 text-muted" style="background-color: #f3f3f5;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
                    </span>
                    <input type="search" value="<%= locals.search || '' %>" id="searchCustomer" name="search" class="form-control border-0 shadow-none" placeholder="search orders..." style="background-color: #f3f3f5;" autofocus>
                </div>
                <a href="/admin/orders" class="btn btn-danger btn-sm rounded-2">Cancel</a>
                <button class="btn btn-primary btn-sm fw-semibold rounded-2">Submit</button>
                <select name="couponStatus" id="couponStatus" class="form-select form-select-sm w-auto shadow-none text-dark rounded-2" style="min-width: 200px; font-size: 15px; border-color: #f2f2f2;">
                    <option value="all-status">All Status</option>
                    <option value="active">Active</option>
                    <option value="expired">Expired</option>
                    <option value="inactive">Inactive</option>
                </select>
            </form>
        </div>

        <div class="bg-white mt-4 px-3 py-4 border rounded-4" style="min-height: 500px; display: block; min-width: 100%;">
            <div>
                <h5>All Coupons</h5>
            </div>
            <table class="table mt-4">
                <thead>
                    <th scope="col">Code</th>
                    <th scope="col">Description</th>
                    <th scope="col">Discount</th>
                    <th scope="col">Min Purchase</th>
                    <th scope="col">Usage</th>
                    <th scope="col">Valid Period</th>
                    <th scope="col">Status</th>
                    <th scope="col">Actions</th>
                </thead>
                <tbody>
                    <!-- <% const options = { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }; %> -->
                    <% locals.coupons.forEach((coupon) => { %>
                        <tr class="table" data-item-id="<%= coupon._id %>">
                            <th scope="row"> <%= coupon.code %> </th>
                            <td> <%= coupon.description %> </td>
                            <td>
                                <% if (coupon.discountType === "percentage") { %>
                                    <%= coupon.discountValue %>% <span class="text-muted small">(max ₹<%= coupon.maxDiscountAmount %>)</span>
                                <% } %>
                            </td>
                            <td>₹<%= coupon.minPurchaseAmount %></td>
                            <td><%= coupon.users.length %>/<%= coupon.usageLimit %></td>
                            <td> <%= coupon.expiryDate.toLocaleDateString('en-US', options) %></td>
                            <td>
                                <% if (coupon.isActive) { %>
                                    <button class="btn btn-dark btn-sm rounded-2 btn-badge">Active</button>
                                <% } else { %>
                                    <button class="btn btn-light border rounded-2 btn-badge">Inactive</button>
                                <% } %>
                            </td>
                            <td>
                                <div class="dropdown">
                                    <button type="button" class="btn btn-light rounded-2" data-bs-toggle="dropdown" aria-haspopup="true" data-bs-offset="70,5" aria-expanded="false">⋮</button>
                                    <ul class="dropdown-menu">
                                        <li class="dropdown-item">
                                            <a href="/admin/coupons/edit/<%= coupon._id %>" class="dropdown-item-text small text-decoration-none">
                                                <img src="/images/edit.svg" alt="edit icon" class="me-2">
                                                Edit
                                            </a>
                                        </li>
                                        <li class="dropdown-item">
                                            <span class="dropdown-item-text small">
                                                <img src="/images/delete.svg" alt="trash icon" class="me-2">
                                                Delete
                                            </span>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
    <%- include('partials/admin-footer.ejs') %>

    <div class="toast-container position-fixed top-0 end-0 px-3 mt-5">
        <div id="actionToast" class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body d-flex gap-2 align-items-center fw-bold">
                    <svg id="toast-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" height="20" width="20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"></path></svg>

                    <div id="actionToastBody">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/scripts/coupons.js"></script>
</body>
</html>

