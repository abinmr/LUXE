<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>LUXE</title>
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
            crossorigin="anonymous"
        />
        <script
            src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"
        ></script>
        <link rel="stylesheet" href="/styles/navbar.css" />
    </head>
    <body>
        <%- include('partials/navbar.ejs'), { categories } %>
        <section class="position-relative overflow-hidden" style="height: 600px">
            <img src="/images/hero-banner.png" alt="hero section image" class="w-100 object-fit-cover" />
            <div class="position-absolute d-flex align-items-center text-white" style="inset: 0px; background: linear-gradient(to right, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0) 100%)">
                <div class="container">
                    <div class="text-white" style="max-width: 36rem">
                        <h3 class="display-5 fw-bold" style="font-family: serif">New Collection 2026</h3>
                        <p class="fw-medium" style="font-size: 18px">Discover the latest trends in fashion. Premium quality, timeless style.</p>
                        <button class="btn btn-danger mt-3 px-4">Shop Now</button>
                    </div>
                </div>
            </div>
        </section>
        <section class="bg-danger py-2 mb-5 text-center">
            <p class="text-white mb-0 fw-semibold">🎉 Flat 40% Off on All Items | Free Shipping on Orders Over $100</p>
        </section>
<section class="mb-5">
    <div class="container">
        <h3 class="fs-2 fw-bolder text-center">Shop by Category</h3>
        <div class="d-flex gap-3 mt-4 overflow-x-auto pb-2">
            <% categories.forEach((category) => { %>
                <a href="#" class="rounded-3 overflow-hidden position-relative d-block text-decoration-none flex-shrink-0" style="height: 410px; width: 310px;">
                    <img src="<%= category.image %>" alt="<%= category.name %>"
                         class="w-100 h-100 object-fit-cover" />
                    <div class="position-absolute bottom-0 start-0 w-100"
                         style="background: linear-gradient(to top, rgba(0,0,0,0.6), transparent); height: 80px;"></div>
                    <h5 class="position-absolute bottom-0 start-0 text-white fw-semibold m-0 p-3 z-3">
                        <%= category.name %>
                    </h5>
                </a>
            <% }) %>
        </div>
    </div>
</section>

        <section>
            <div class="container">
                <h3 class="fw-bolder">Products</h3>
                <div class="d-flex gap-3 mt-4 pb-2">
                    <% locals.products.forEach((product) => { %>
                    <% if (product.variants && product.variants.length > 0) { %>
                    <div class="border rounded-3 pb-4">
                        <a href="/product/<%= product._id %>" class="text-decoration-none">
                            <img src="<%= product.variants[0].images %>" alt="<%= product.name %>" class="rounded-3" style="height: 410px; width: 310px;">
                        </a>
                        <div class="px-3">
                            <div class="mt-3">
                                <p class="fw-semibold mb-1"> <%= product.name %> </p>
                                <p class="fw-bold fs-5">₹<%= product.variants[0].sizes[0].price %> <span class="text-decoration-line-through text-muted fw-medium">₹<%= product.variants[0].sizes[0].compareAtPrice %></span> </p>
                            </div>
                            <a href="/cart/add/<%= product._id %>" class="btn btn-danger rounded-3 w-100 fw-semibold d-flex justify-content-center align-items-center gap-3">
<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shopping-cart mr-2 h-4 w-4" aria-hidden="true"><circle cx="8" cy="21" r="1"></circle><circle cx="19" cy="21" r="1"></circle><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path></svg>
                                Add to Cart
                            </a>
                        </div>
                    </div>
                    <% } %>
                    <% }) %>
                </div>
            </div>
        </section>

        <%- include('partials/footer.ejs'), { categories } %>

        <% if (locals.toast) { %>
            <div class="toast-container position-fixed bottom-0 end-0 p-3 m-2">
                <div id="actionToast" class="toast align-items-center" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="d-flex">
                        <div class="toast-body fw-semibold <%= locals.toast.type === 'success' ? 'text-success' : 'text-danger' %>">
                            <%= locals.toast.message %>
                        </div>
                    </div>
                </div>
            </div>

            <script>
                document.addEventListener("DOMContentLoaded", () => {
                    const toastEl = document.getElementById("actionToast");
                    const toast = new bootstrap.Toast(toastEl, { delay: 3000 });
                    toast.show();
                });
            </script>
        <% } %>
    </body>
</html>
