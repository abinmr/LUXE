<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>LUXE</title>
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
            crossorigin="anonymous"
        />
        <script
            src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"
        ></script>
        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
            integrity="sha384-tViUnnbYAV00FLIhhi3v/dWt3Jxw4gZQcNoSCxCIFNJVCx7/D55/wXsrNIRANwdD"
            crossorigin="anonymous"
        />
        <link rel="stylesheet" href="/styles/navbar.css" />
    </head>
    <body>
        <%- include('partials/navbar.ejs') %>
        <section class="position-relative overflow-hidden" style="height: 600px">
            <img src="/images/hero-banner.png" alt="hero section image" class="w-100 object-fit-cover" />
            <div class="position-absolute d-flex align-items-center text-white" style="inset: 0px; background: linear-gradient(to right, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0) 100%)">
                <div class="container">
                    <div class="text-white" style="max-width: 36rem">
                        <h3 class="display-5 fw-bold" style="font-family: serif">New Collection 2026</h3>
                        <p class="fw-medium" style="font-size: 18px">Discover the latest trends in fashion. Premium quality, timeless style.</p>
                        <button class="btn btn-danger mt-3 px-4">Shop Now</button>
                    </div>
                </div>
            </div>
        </section>
        <section class="bg-danger py-2 mb-5 text-center">
            <p class="text-white mb-0 fw-semibold">🎉 Flat 40% Off on All Items | Free Shipping on Orders Over ₹100</p>
        </section>

        <section class="mb-5">
            <div class="container-xl">
                <h3 class="fs-2 fw-bolder text-center">Shop by Category</h3>
                <div class="d-flex gap-3 mt-4 overflow-x-auto pb-2">
                    <% categories.forEach((category) => { %>
                        <a href="/category/<%= category._id %>" class="rounded-3 overflow-hidden position-relative d-block text-decoration-none flex-shrink-0" style="height: 410px; width: 310px;">
                            <img src="<%= category.image %>" alt="<%= category.name %>"
                                class="w-100 h-100 object-fit-cover img-animation" />
                            <div class="position-absolute bottom-0 start-0 w-100"
                                style="background: linear-gradient(to top, rgba(0,0,0,0.6), transparent); height: 80px;"></div>
                            <h5 class="position-absolute bottom-0 start-0 text-white fw-semibold m-0 p-3 z-3">
                                <%= category.name %>
                            </h5>
                        </a>
                    <% }) %>
                </div>
            </div>
        </section>

<section>
    <div class="container-xxl">
        <h3 class="fw-bolder mb-0">Products</h3>

        
        <div id="product-container" class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4 mt-2 pb-5">
        </div>
        <h6 id="loading" class="text-center fw-bold">loading...</h6>
    </div>
</section>

        <%- include('partials/footer.ejs', { categories }) %>

            <div class="toast-container position-fixed top-0 end-0 px-3 pt-5 mt-5">
                <div id="actionToast" class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="d-flex">
                        <div class="toast-body d-flex gap-2 align-items-center fw-bold">
                            <svg id="toast-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" height="20" width="20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"></path></svg>

                            <div id="actionToastBody">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        <% if (locals.toast) { %>
            <script>
                window.initialToast = {
                    message: "<%= locals.toast.message %>",
                    type: "<%= locals.toast.type %>"
                };
            </script>
        <% } %>
            <script src="/scripts/home.js"></script>
    </body>
</html>
