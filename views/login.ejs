<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>LUXE</title>
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
            crossorigin="anonymous"
        />
        <script
            src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"
        ></script>
        <link rel="stylesheet" href="/styles/register.css" />
        <script defer src="/scripts/login.js"></script>
    </head>
    <body>
        <div class="container d-flex justify-content-center align-items-center min-vh-100">
            <div class="border shadow-sm w-50 rounded-4 form-container">
                <div class="text-center mt-4">
                    <h2 class="fs-1 py-3 fw-bold" style="font-family: serif">LUXE</h2>
                    <h4 class="fs-4">Welcome Back</h4>
                    <p class="text-muted">Login to your account</p>
                </div>
                <p class="text-center mb-0 mt-1 text-danger" style="visibility: <%= locals.error ? 'visible' : 'hidden' %>;"><%= locals.error || 'Placeholder' %></p>
                <form action="/api/auth/login" method="POST" class="d-flex flex-column align-items-center pt-2" id="form">
                    <div class="mb-1 w-75">
                        <label for="email" class="form-label">Email</label>
                        <input class="form-control" type="email" name="email" placeholder="you@email.com" id="email" />
                        <div class="mt-1 error-container">
                            <p class="text-danger small mb-0" id="emailError" style="visibility: <%= locals.emailError ? 'visible' : 'hidden' %>;"><%= locals.emailError || 'Placeholder' %></p>
                        </div>
                    </div>
                    <div class="mb-1 w-75">
                        <label for="password" class="form-label">Password</label>
                        <input class="form-control" type="password" name="password" placeholder="password" id="password" />
                        <div class="mt-1 error-container">
                            <p class="text-danger small mb-0" id="passwordError" style="visibility: <%= locals.passwordError ? 'visible' : 'hidden' %>;">
                                <%= locals.passwordError || 'Placeholder' %>
                            </p>
                        </div>
                    </div>
                    <button type="submit" class="btn text-light mt-1 w-75 btn-main">Login</button>
                    <a href="/api/auth/login/reset-password" class="mt-3 text-muted text-decoration-none forget-pass">Forgot password?</a>
                </form>
                <div class="col-9 mx-auto">
                    <div class="d-flex align-items-center my-4">
                        <div class="flex-grow-1 border-bottom"></div>
                        <span class="px-3 text-secondary" style="color: #637b92 !important">OR</span>
                        <div class="flex-grow-1 border-bottom"></div>
                    </div>
                    <button class="google-btn btn mb-3 w-75 mx-auto d-flex justify-content-center align-items-center gap-2">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"></path>
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"></path>
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"></path>
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"></path>
                        </svg>
                        Continue with Google
                    </button>
                </div>
                <p class="text-muted text-center mb-4">Don't have an account? <a href="/api/auth/register" class="link text-decoration-none">Register</a></p>
            </div>
        </div>
    </body>
</html>
