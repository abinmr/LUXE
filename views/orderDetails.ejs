<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LUXE</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/styles/navbar.css" />
</head>
<body style="background-color: #fefbf8;">
    <%- include('partials/navbar.ejs') %>
    <div class="container-xl mt-5">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a class="text-decoration-none" href="/">Home</a></li>
                <li class="breadcrumb-item"><a class="text-decoration-none" href="/profile">Profile</a></li>
                <li class="breadcrumb-item"><a class="text-decoration-none" href="/profile?section=order-history">Orders</a></li>
                <li class="breadcrumb-item active" aria-current="page">order id</li>
            </ol>
        </nav>

        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-center align-items-lg-start gap-4 mt-4">
            <div class="w-100">
                <div class="border border-1 rounded-4 p-4 bg-white mb-4 shadow-sm">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-package h-5 w-5" aria-hidden="true"><path d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z"></path><path d="M12 22V12"></path><polyline points="3.29 7 12 12 20.71 7"></polyline><path d="m7.5 4.27 9 5.15"></path></svg>
                            <span class="responsive-title">Order #<%= orderDetails.orderId %></span>
                        </div>
                        <div class="d-flex flex-column flex-sm-row align-items-center gap-3">
                            <% const displayStatus = orderDetails.items[0].orderStatus || 'pending'; %>
                            <button id="order-status" class="btn btn-sm <%= (displayStatus === "cancelled" || displayStatus === "return-requested") ? 'btn-danger' : "btn-light border" %> rounded-2"> <%= displayStatus === "return-requested" ? 'Return requested' : displayStatus %> </button>
                            <% if (orderDetails.paymentStatus === "paid" || orderDetails.paymentMethod === "cod") { %>
                            <a href="/profile/orders/<%= orderDetails._id %>/invoice" target="_blank" class="btn btn-light btn-sm rounded-2 border d-flex align-items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-download h-3.5 w-3.5" aria-hidden="true"><path d="M12 15V3"></path><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><path d="m7 10 5 5 5-5"></path></svg>
                                invoice
                            </a>
                            <% } %>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Order Date</span>
                        <span>4/17/2026</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Total Amout</span>
                        <span>₹<%= orderDetails.total %></span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <% const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }; %>
                        <span>Expected Arrival</span>
                        <span> <%= orderDetails.estimatedDeliveryDate ? orderDetails.estimatedDeliveryDate.toLocaleDateString("en-US", options) : 'N/A' %></span>
                    </div>
                </div>

                <div class="border border-1 rounded-4 p-4 bg-white shadow-sm">
                    <p>Order Items</p>
                    <% orderDetails.items.forEach((item, i) => { %>
                        <% const status = item.orderStatus || 'pending';
                            const terminalStatues = ["cancelled", "return-requested", "returned"];
                            const isTerminal = terminalStatues.includes(status);
                            const isDelivered = status === "delivered";
                            const returnWindowOpen = isDelivered && orderDetails.estimatedDeliveryDate && new Date() < new Date(orderDetails.estimatedDeliveryDate.getTime() + 7 * 24 * 60 * 60 * 1000);
                        %>
                        <% if (i !== 0) { %>
                        <hr class="text-muted">
                        <% } %>
                        <div class="mt-2 d-flex justify-content-between align-items-center gap-4">
                            <div class="d-flex align-items-start gap-3">
                                <img src="<%= item.productImage %>" alt="<%= item.productName %>" class="rounded-2 object-fit-cover" height="140" width="140">
                                <div>
                                    <p class="mb-1 fw-bold responsive-title"> <%= item.productName %></p>
                                    <div>
                                        <span>Size: <span class="fw-semibold"> <%= item.size %> </span></span>
                                        <span>Color: <span class="fw-semibold"> <%= item.color %> </span></span>
                                    </div>
                                    <div class="d-flex flex-column">
                                        <span>Qty: <span class="fw-semibold"> <%= item.quantity %> </span></span>
                                        <span class="fw-bold">₹<%= item.price %></span>
                                    </div>
                                    <div>
                                        <button id="item-status-<%= item._id %>" class="btn <%= isDelivered ? 'btn-success' : 'btn-danger' %> btn-sm rounded-2 mt-2"><%= item.orderStatus %></button>
                                    </div>
                                </div>
                            </div>
                            <% if (!isTerminal) { %>
                                <% if (returnWindowOpen) { %>
                                    <button class="btn btn-danger btn-sm return-btn rounded-2" data-bs-toggle="modal" data-bs-target="#returnModal" data-item-id="<%= item._id %>">Return</button>
                                <% } else if (!isDelivered) { %>
                                    <% const canCancel = orderDetails.paymentMethod === "cod" || orderDetails.paymentMethod === "wallet" || orderDetails.paymentStatus === "paid"; %>
                                    <% if (canCancel) { %>
                                        <button class="btn btn-outline-danger btn-sm cancel-btn rounded-2" data-bs-toggle="modal" data-bs-target="#cancelModal" data-item-id="<%= item._id %>">Cancel</button>
                                    <% } %>
                                <% } %>
                            <% } %>
                        </div>
                    <% }); %>
                </div>
            </div>

            <div class="col-12 col-md-10 col-lg-4">
                <div class="border border-1 rounded-4 p-4 bg-white shadow-sm mb-4">
                    <div>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin h-5 w-5" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path><circle cx="12" cy="10" r="3"></circle></svg>
                        <span>Shipping Address</span>
                    </div>
                    <div class="d-flex flex-column mt-2">
                        <span class="fw-bold mb-1"> <%= orderDetails.shippingAddress.fullName %> </span>
                        <span class="text-muted mb-1"> <%= orderDetails.shippingAddress.houseNumber %>, <%= orderDetails.shippingAddress.street %> </span>
                        <span class="text-muted mb-1"> <%= orderDetails.shippingAddress.state %> <%= orderDetails.shippingAddress.pincode %> </span>
                        <span class="text-muted mb-1">Phone: <%= orderDetails.shippingAddress.phone %> </span>
                    </div>
                </div>

                <div class="border border-1 rounded-4 p-4 bg-white shadow-sm mb-4">
                    <div class="mb-2 d-flex align-items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-credit-card h-5 w-5" aria-hidden="true"><rect width="20" height="14" x="2" y="5" rx="2"></rect><line x1="2" x2="22" y1="10" y2="10"></line></svg>
                        <span class="h5 fw-bold mb-0">Payment Method</span>
                    </div>
                    <div class="pt-2">
                        <% if (orderDetails.paymentMethod === "cod") { %>
                            <p class="fw-semibold h5">Cash on Delivery</p>
                        <% } else if (orderDetails.paymentMethod === "wallet") { %>
                            <p class="fw-semibold h5">Wallet</p>
                        <% } else if (orderDetails.paymentMethod === "card") {%>
                            <p class="fw-semibold h5">Card</p>
                        <% } else if (orderDetails.paymentMethod === "upi") { %>
                            <p class="fw-semibold h5">UPI</p>
                        <% } else { %>
                            <p class="fw-semibold h5"><%= orderDetails.paymentMethod %></p>
                        <% } %>
                        <div class="d-flex align-items-center gap-2 mt-1">
                            <span class="small text-muted">Status:</span>
                            <span class="badge <%= orderDetails.paymentStatus === 'paid' ? 'bg-success' : (orderDetails.paymentStatus === 'failed' ? 'bg-danger' : 'bg-warning') %> text-capitalize">
                                <%= orderDetails.paymentStatus %>
                            </span>
                        </div>

                        <% if (orderDetails.paymentStatus !== "cod" && (orderDetails.paymentStatus === "failed" || orderDetails.paymentStatus === "pending")) { %>
                            <button id="retry-payment-btn" class="btn btn-danger btn-sm mt-3 w-100 rounded-2" data-id="<%= orderDetails._id %>">
                                Retry Payment
                            </button>
                        <% } %>
                    </div>
                </div>

                <div class="border border-1 rounded-4 p-4 bg-white shadow-sm">
                    <p class="fw-semibold">Price Details</p>
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Subtotal</span>
                        <span class="fw-semibold">₹<%= orderDetails.subtotal %></span>
                    </div>
                    <% if (orderDetails.discount > 0) { %>
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Discount</span>
                            <span class="fw-semibold text-danger"> -₹<%= orderDetails.discount %> </span>
                        </div>
                    <% } %>
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">GST</span>
                        <span class="fw-semibold">₹<%= orderDetails.GST %></span>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Shipping</span>
                        <span class="fw-semibold">₹<%= orderDetails.shipping %></span>
                    </div>
                    <hr class="text-muted">
                    <div class="d-flex justify-content-between">
                        <span class="fw-bold" style="font-size: 18px;">Total</span>
                        <span class="fw-bolder">₹<%= orderDetails.total %></span>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content p-2">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Reson for cancelling</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="cancel-form" data-id="<%= orderDetails._id %>">
                    <div class="modal-body">
                        <label for="reason1" class="form-check-label p-3 border rounded-4 w-100 mb-2">
                            <input type="radio" name="reason" value="Changed my mind" id="reason1" class="form-check-input ms-1">
                            Changed my mind
                        </label>
                        <label for="reason2" class="form-check-label p-3 border rounded-4 w-100 mb-2">
                            <input type="radio" name="reason" value="Found a better price elsewhere" id="reason2" class="form-check-input ms-1">
                            Found a better price elsewhere
                        </label>
                        <label for="reason3" class="form-check-label p-3 border rounded-4 w-100 mb-2">
                            <input type="radio" name="reason" value="Ordered by mistake" id="reason3" class="form-check-input ms-1">
                            Ordered by mistake
                        </label>
                        <label for="reason4" class="form-check-label p-3 border rounded-4 w-100 mb-2">
                            <input type="radio" name="reason" value="Item take too long to arrive" id="reason4" class="form-check-input ms-1">
                            Item take too long to arrive
                        </label>
                        <label for="reason5" class="form-check-label p-3 border rounded-4 w-100 mb-2">
                            <input type="radio" name="reason" value="Other" id="reason5" class="form-check-input ms-1">
                            Other
                        </label>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-light border rounded-2" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger rounded-2" id="continue" disabled>Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="returnModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content p-2">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Reson for return</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="return-form" data-id="<%= orderDetails._id %>">
                    <div class="modal-body">
                        <label for="return-reason1" class="form-check-label p-3 border rounded-4 w-100 mb-2">
                            <input type="radio" name="reason" value="Item arrived damaged" id="return-reason1" class="form-check-input ms-1">
                            Item arrived damaged
                        </label>
                        <label for="return-reason2" class="form-check-label p-3 border rounded-4 w-100 mb-2">
                            <input type="radio" name="reason" value="Improper fit" id="return-reason2" class="form-check-input ms-1">
                            Improper fit
                        </label>
                        <label for="return-reason3" class="form-check-label p-3 border rounded-4 w-100 mb-2">
                            <input type="radio" name="reason" value="Product not matching the description" id="return-reason3" class="form-check-input ms-1">
                            Product not matching the description
                        </label>
                        <label for="return-reason4" class="form-check-label p-3 border rounded-4 w-100 mb-2">
                            <input type="radio" name="reason" value="Size to small / too large" id="return-reason4" class="form-check-input ms-1">
                            Size to small / too large
                        </label>
                        <label for="return-reason5" class="form-check-label p-3 border rounded-4 w-100 mb-2">
                            <input type="radio" name="reason" value="Color different from what was shown" id="return-reason5" class="form-check-input ms-1">
                            Color different from what was shown
                        </label>
                        <label for="return-reason6" class="form-check-label p-3 border rounded-4 w-100 mb-2">
                            <input type="radio" name="reason" value="Other" id="return-reason6" class="form-check-input ms-1">
                            Other
                        </label>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-light border rounded-2" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger rounded-2" id="continue-return" disabled>Return</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="toast-container position-fixed top-0 end-0 px-3 pt-5 mt-5">
        <div id="actionToast" class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body d-flex gap-2 align-items-center fw-bold">
                    <svg id="toast-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" height="20" width="20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"></path></svg>

                    <div id="actionToastBody">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer.ejs') %>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script src="/scripts/orderDetails.js"></script>
</body>
</html>
