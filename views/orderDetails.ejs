<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LUXE</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/styles/navbar.css" />
</head>
<body style="background-color: #fefbf8;">
    <%- include('partials/navbar.ejs') %>
    <div class="container mt-5">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a class="text-decoration-none" href="/">Home</a></li>
                <li class="breadcrumb-item"><a class="text-decoration-none" href="/profile">Profile</a></li>
                <li class="breadcrumb-item"><a class="text-decoration-none" href="/profile?section=order-history">Orders</a></li>
                <li class="breadcrumb-item active" aria-current="page">order id</li>
            </ol>
        </nav>

        <div class="d-flex justify-content-between gap-4 mt-4">
            <div class="w-100">
                <div class="border border-1 rounded-4 p-4 bg-white mb-4 shadow-sm">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-package h-5 w-5" aria-hidden="true"><path d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z"></path><path d="M12 22V12"></path><polyline points="3.29 7 12 12 20.71 7"></polyline><path d="m7.5 4.27 9 5.15"></path></svg>
                            <span>Order #<%= orderDetails.orderId %></span>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <button class="btn btn-light btn-sm"> <%= orderDetails.orderStatus %> </button>
                            <a href="/profile/orders/<%= orderDetails._id %>/invoice" target="_blank" class="btn btn-light btn-sm border d-flex align-items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-download h-3.5 w-3.5" aria-hidden="true"><path d="M12 15V3"></path><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><path d="m7 10 5 5 5-5"></path></svg>
                                invoice
                            </a>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Order Date</span>
                        <span>4/17/2026</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Total Amout</span>
                        <span>₹<%= orderDetails.total %></span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <% const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }; %>
                        <span>Expected Arrival</span>
                        <span> <%= orderDetails.estimatedDeliveryDate.toLocaleDateString("en-US", options) %></span>
                    </div>
                </div>

                <div class="border border-1 rounded-4 p-4 bg-white shadow-sm">
                    <p>Order Items</p>
                    <% orderDetails.items.forEach((item, i) => { %>
                        <% if (i !== 0) { %>
                        <hr class="text-muted">
                        <% } %>
                        <div class="mt-2 d-flex align-items-center gap-4">
                            <div class="mb-3">
                                <img src="<%= item.productImage %>" class="rounded-2" height="80" width="80">
                            </div>
                            <div>
                                <p class="mb-1 fw-bold"> <%= item.productName %></p>
                                <div>
                                    <span>Size: <span class="fw-semibold"> <%= item.size %> </span></span>
                                    <span>Color: <span class="fw-semibold"> <%= item.color %> </span></span>
                                </div>
                                <div class="d-flex flex-column">
                                    <span>Qty: <span class="fw-semibold"> <%= item.quantity %> </span></span>
                                    <span class="fw-bold">₹<%= item.price %></span>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
                <button id="cancel-btn" class="btn btn-danger w-100 my-4" data-order-id="<%= orderDetails._id %>" data-bs-toggle="modal" data-bs-target="#cancelModal" >Cancel</button>
            </div>

            <div class="w-50">
                <div class="border border-1 rounded-4 p-4 bg-white shadow-sm mb-4">
                    <div>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin h-5 w-5" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path><circle cx="12" cy="10" r="3"></circle></svg>
                        <span>Shipping Address</span>
                    </div>
                    <div class="d-flex flex-column mt-2">
                        <span class="fw-bold mb-1"> <%= orderDetails.shippingAddress.fullName %> </span>
                        <span class="text-muted mb-1"> <%= orderDetails.shippingAddress.houseNumber %>, <%= orderDetails.shippingAddress.street %> </span>
                        <span class="text-muted mb-1"> <%= orderDetails.shippingAddress.state %> <%= orderDetails.shippingAddress.pincode %> </span>
                        <span class="text-muted mb-1">Phone: <%= orderDetails.shippingAddress.phone %> </span>
                    </div>
                </div>

                <div class="border border-1 rounded-4 p-4 bg-white shadow-sm mb-4">
                    <div class="mb-4 d-flex align-items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-credit-card h-5 w-5" aria-hidden="true"><rect width="20" height="14" x="2" y="5" rx="2"></rect><line x1="2" x2="22" y1="10" y2="10"></line></svg>
                        <span class="h5 fw-bold mb-0">Payment Method</span>
                    </div>
                    <div class="pt-2">
                        <% if (orderDetails.paymentMethod === "cod") { %>
                            <p class="fw-semibold">Cash on Delivery</p>
                        <% } %>
                    </div>
                </div>

                <div class="border border-1 rounded-4 p-4 bg-white shadow-sm">
                    <p class="fw-semibold">Price Details</p>
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Subtotal</span>
                        <span class="fw-semibold">₹<%= orderDetails.subtotal %></span>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">GST</span>
                        <span class="fw-semibold">₹<%= orderDetails.GST %></span>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Shipping</span>
                        <span class="fw-semibold">₹<%= orderDetails.shipping %></span>
                    </div>
                    <hr class="text-muted">
                    <div class="d-flex justify-content-between">
                        <span class="fw-bold" style="font-size: 18px;">Total</span>
                        <span class="fw-bolder">₹<%= orderDetails.total %></span>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content p-2">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Reson for cancelling</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="cancel-form">
                    <div class="modal-body">
                        <div>
                            <label for="reason" class="form-label">Reason</label>
                            <textarea class="form-control" name="reason" id="reason-textarea" rows="10" placeholder="Reason for cancelling" style="resize: none;" data-id="<%= orderDetails._id %>"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-light border rounded-2" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger rounded-2" id="continue" disabled>Continue</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include('partials/footer.ejs') %>
    <script src="/scripts/orderDetails.js"></script>
</body>
</html>
